
---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
    <main class="min-h-screen bg-black px-8 py-12 text-white space-y-8">

			<!-- Typography Role Audit -->
			<section class="space-y-0 border-t border-white/10 pt-16">

					<!-- Hero Brush Assets-->
					<section class="space-y-0">
						<div class="space-y-0">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Hero Brush Assets
							</p>
						</div>
						<div class="grid gap-1 md:grid-cols-1">
							<!-- Hero Brush Primary -->
							<div class="space-y-0">
								<h1 class="type-druk-hero">
									The Ultimate
								</h1>
							</div>
							<!-- Druk Hero Clean -->
							<div class="space-y-0">
								<h1 class="type-druk-clean">
									The Ultimate
								</h1>
							</div>
							<div class="space-y-0 ">
										<h1 class="type-brush-hero">
											Playground
										</h1>	
							</div>
							<div class="space-y-0">
								<h1 class="type-druk-gold">
									For Serious Collectors
								</h1>
							</div>
							<div class="space-y-0">
								<h1 class="type-brush-secondary">
									Bunker's <br>
									Bargains
								</h1>
							</div>

							<!-- Brush Price Accent -->
							<div class="space-y-2">
								<p class="type-brush-price">
									$49.99
								</p>
							</div>

						</div>
						</section>

					<section class="space-y-0">
						<div class="space-y-0">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								UI Statement Assets
							</p>
						</div>

						<div class="grid gap-1 md:grid-cols-1">

							<!-- UI Statement Text 1 -->
							<div class="space-y-0">
								<p class="type-ui-statement-polish">
									Premium cards.
								</p>
							</div>

							<!-- UI Statement Text 2 -->
							<div class="space-y-0">
								<p class="type-ui-statement-gold">
									Elite service.
								</p>
							</div>

							<!-- UI Statement Text 3 -->
							<div class="space-y-0">
								<h3 class="type-ui-statement-bold">
									Motion adds energy.
								</h3>
							</div>
						</div>
						</section>

					<section class="space-y-0">
						<div class="space-y-0">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Titling Assets
							</p>
						</div>

						<div class="grid gap-1 md:grid-cols-1">

							<!-- Product Title -->
							<div class="space-y-0">
								<p class="type-product-title">
									Product Title
								</p>
							</div>

							<!-- Panel Title -->
							<div class="space-y-0">
								<p class="type-panel-title">
									Panel Title
								</p>
							</div>

							<!-- Section Title -->
							<div class="space-y-0">
								<p class="type-section-title">
									Section Title
								</p>
							</div>

						</div>
						</section>






					<section class="space-y-0">
						<div class="space-y-0">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Labeling Assets
							</p>
						</div>

						<div class="grid gap-0 md:grid-cols-1">

							<!-- Context Label -->
							<div class="space-y-0">
								<p class="type-context-label">
									Context Label
								</p>
							</div>

							<!-- Eyebrow Label -->
							<div class="space-y-0">
								<p class="type-eyebrow-label">
									Eyebrow Label
								</p>
							</div>

							<!-- Metadata Label -->
							<div class="space-y-0">
								<p class="type-metadata">
									Metadata Label
								</p>
							</div>

							<!-- Status Label -->
							<div class="space-y-0">
								<p class="type-status-label">
									Status Label
								</p>
							</div>

						</div>
						</section>

					<!-- Action Assets-->
					<section class="space-y-0">
						<div class="space-y-0">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Action Assets
							</p>
						</div>

						<div class="grid gap-0 md:grid-cols-1">

							<!-- Action Label -->
							<div class="space-y-0">
								<button class="rounded-full px-5 py-2 type-action-label">
									Action Label
								</button>
							</div>

							<!-- CTA Label -->
							<div class="space-y-0">
								<p class="type-cta-label">
									View PlayerPulse →
								</p>
							</div>

						</div>
						</section>

					<section class="space-y-0">
						<div class="space-y-0">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Commerce/Data Assets
							</p>
						</div>

						<div class="grid gap-0 md:grid-cols-1">

							<!-- Data Timer -->
							<div class="space-y-0">
								<p class="type-data-timer">
									07 : 34 : 21
								</p>
							</div>

							<div class="space-y-0">
								<p class="type-countdown-timer">
									02D : 11H : 48M
								</p>
							</div>
							<div class="space-y-0">
								<p class="type-price-primary">
									$249.99
								</p>
							</div>
							<div class="space-y-0">
								<p class="type-price-compare">
									$299.99
								</p>
							</div>
							<div class="space-y-2">
								<p class="type-price-savings">
									You Save $50.00 (17%)
								</p>
							</div>
						</div>
						</section>

					<section class="space-y-0">
						<div class="space-y-0">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Body Copy Assets
							</p>
							<p class="type-body">
								Reusable paragraph and informational text styles used throughout the interface.
							</p>
						</div>

						<div class="grid gap-0 md:grid-cols-1">

							<!-- Prominent -->
							<div class="space-y-0">
								<p class="type-body-prominent">
									Used for featured supporting copy in hero sections and marketing moments.
								</p>
							</div>

							<!-- Quiet -->
							<div class="space-y-0">
								<p class="type-body-quiet">
									Used for notes, metadata support, and de-emphasized informational text.
								</p>
							</div>

							<!-- Overlay -->
							<div class="space-y-0">
								<p class="type-body-overlay">
									Used over dark imagery, overlays, and high-contrast visual surfaces.
								</p>
							</div>

						</div>
						</section>
			
				</div>
			</section>


    </main>

</layout>