
---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
    <main class="min-h-screen bg-black px-18 py-12 text-white space-y-8">

			<!-- Typography Role Audit -->
			<section class="space-y-10 border-t border-white/10 pt-16">

					<!-- Hero Brush Assets-->
					<section class="space-y-8">
						<div class="space-y-2">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Hero Brush Assets
							</p>
								
							<p class="text-base leading-relaxed text-slate-400">
								Reusable RoadRage-style hero brush text elements used throughout the interface.
							</p>
						</div>

						<div class="grid gap-8 md:grid-cols-2">

							<!-- Hero Brush Primary -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">Hero Brush Primary</p>
								<h3 class="[font-family:'RoadRage'] bg-gradient-to-b from-yellow-100 via-yellow-400 to-yellow-900 bg-clip-text text-6xl uppercase leading-none tracking-[-0.08em] text-transparent drop-shadow-[0_8px_0_rgba(0,0,0,0.75)] md:text-8xl">
									Playground
								</h3>
							</div>

							<!-- Hero Brush Secondary -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Hero Brush Secondary</p>
								<h1 class="[font-family:'RoadRage'] text-3xl uppercase tracking-[0.06em] leading-none bg-gradient-to-b from-white via-slate-200 to-slate-500 bg-clip-text text-transparent drop-shadow-[0_6px_0_rgba(0,0,0,0.7)]">
									Bunker's Bargains
								</h1>
							</div>

							<!-- Brush Price Accent -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Brush Price Accent</p>
								<p class="[font-family:'RoadRage'] bg-gradient-to-b from-yellow-100 via-yellow-400 to-yellow-900 bg-clip-text text-2xl uppercase leading-none text-transparent">
									$49.99
								</p>
							</div>

						</div>
						</section>

					<!-- Druk Hero Assets-->
					<section class="space-y-8">
						<div class="space-y-2">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Druk Hero Assets
							</p>
								
							<p class="text-base leading-relaxed text-slate-400">
								Reusable Druk-style hero text elements used throughout the interface.
							</p>
						</div>

						<div class="grid gap-8 md:grid-cols-2">

							<!-- Druk Hero Emphasis -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">Druk Hero Emphasis</p>
								<h1 class="[font-family:'Druk'] text-6xl uppercase tracking-[0.06em] leading-[0.9] scale-y-90 skew-x-[-4deg] 
								bg-gradient-to-b from-white via-slate-100 via-slate-300 to-slate-700 
								bg-clip-text shadow-lg text-transparent drop-shadow-[0_9px_0_rgba(0,0,0,0.9)] transition duration-300 
								hover:scale-105 hover:drop-shadow-[0_10px_0_rgba(0,0,0,0.85)]">
									The Ultimate
								</h1>
							</div>

							<!-- Druk Hero Clean -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Druk Hero Clean</p>
								<h1 class="[font-family:'Druk'] bg-gradient-to-b from-white via-slate-200 to-slate-600 
								bg-clip-text text-3xl tracking-[0.04em] uppercase leading-none text-transparent md:text-5xl">
									The Ultimate
								</h1>
							</div>

							<!-- Druk Gold Accent -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Druk Gold Accent</p>
								<h1 class="[font-family:'Druk'] text-4xl uppercase tracking-[0.08em] leading-[0.9] skew-x-[-4deg] bg-gradient-to-b from-yellow-300 via-amber-500 to-amber-900 bg-clip-text shadow-lg text-transparent drop-shadow-[0_9px_0_rgba(0,0,0,0.9)] transition duration-300 hover:scale-105 hover:drop-shadow-[0_10px_0_rgba(0,0,0,0.85)]">
									For Serious Collectors
								</h1>
							</div>

						</div>
						</section>

					<!-- UI Statement Assets-->
					<section class="space-y-8">
						<div class="space-y-2">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								UI Statement Assets
							</p>
								
							<p class="text-base leading-relaxed text-slate-400">
								Reusable UI Statement text styles used throughout the interface.
							</p>
						</div>

						<div class="grid gap-8 md:grid-cols-2">

							<!-- UI Statement Text 1 -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">UI Statement Text Polish</p>
								<p class="[font-family:'Inter'] text-[1.8rem] leading-[0.84] font-[300] leading-tight tracking-[-0.02em] text-[#f1f1f1]/95">
									Premium cards.
								</p>
							</div>

							<!-- UI Statement Text 2 -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> UI Statement Gold Polish</p>
								<p class="[font-family:'Inter'] text-[1.8rem] leading-[0.84] font-[300] leading-tight tracking-[-0.02em] text-[#d89b16]">
									Elite service.
								</p>
							</div>

							<!-- UI Statement Text 3 -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> UI Statement Text Bold</p>
								<h3 class="[font-family:'Druk'] text-3xl uppercase leading-none text-white">
									Motion should add energy, not noise.
								</h3>
							</div>

							<!-- UI Statement Text 4 -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> UI Statement Text Professional</p>
								<p class="text-2xl font-black tracking-[-0.04em] text-white">
									InnoAV
								</p>
							</div>

							<!-- UI Statement Text 5 -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> UI Statement Text No Glow</p>
								<p class="mt-3 text-lg font-bold text-white">
									No Glow
								</p>
							</div>
						</div>
						</section>

					<!-- Titling Assets-->
					<section class="space-y-8">
						<div class="space-y-2">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Titling Assets
							</p>
								
							<p class="text-base leading-relaxed text-slate-400">
								Reusable Titling text styles used throughout the interface.
							</p>
						</div>

						<div class="grid gap-8 md:grid-cols-2">

							<!-- Product Title -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">Product Title</p>
								<p class="mt-4 text-sm font-medium text-slate-200">
									Product Title
								</p>
							</div>

							<!-- Panel Title -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Panel Title</p>
								<p class="text-xs uppercase tracking-[0.22em] text-amber-500">
									Panel Title
								</p>
							</div>

							<!-- Section Title -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Section Title</p>
								<p class="mt-3 text-xs font-bold uppercase tracking-wide text-amber-400">
									Section Title
								</p>
							</div>

						</div>
						</section>

					<!-- Label Assets-->
					<section class="space-y-8">
						<div class="space-y-2">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Labeling Assets
							</p>
								
							<p class="text-base leading-relaxed text-slate-400">
								Reusable labeling text styles used throughout the interface.
							</p>
						</div>

						<div class="grid gap-8 md:grid-cols-2">

							<!-- Context Label -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">Context Label</p>
								<p class="text-xs uppercase tracking-[0.28em] text-amber-400">
									Context Label
								</p>
							</div>

							<!-- Eyebrow Label -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Eyebrow Label</p>
								<p class="text-xs uppercase tracking-[0.2em] text-slate-500">
									Eyebrow Label
								</p>
							</div>

							<!-- Metadata Label -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Metadata Label</p>
								<p class="text-sm text-slate-500">
									Metadata Label
								</p>
							</div>

							<!-- Status Label -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Status Label</p>
								<p class="text-xs font-bold uppercase tracking-[0.18em] text-green-400">
									Status Label
								</p>
							</div>

						</div>
						</section>

					<!-- Action Assets-->
					<section class="space-y-8">
						<div class="space-y-2">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Action Assets
							</p>
								
							<p class="text-base leading-relaxed text-slate-400">
								Reusable Call to Action related text styles used throughout the interface.
							</p>
						</div>

						<div class="grid gap-8 md:grid-cols-2">

							<!-- Action Label -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Action Label</p>
								<button class="rounded-full px-5 py-2 text-xs font-bold uppercase tracking-wide transition">
									Action Label
								</button>
							</div>

							<!-- CTA Label -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Player CTA</p>
								<p class="mt-3 text-xs font-bold uppercase tracking-wide text-amber-400">
									View PlayerPulse →
								</p>
							</div>

						</div>
						</section>

					<!-- Commerce/Data Assets-->		
					<section class="space-y-8">
						<div class="space-y-2">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Commerce/Data Assets
							</p>
								
							<p class="text-base leading-relaxed text-slate-400">
								Reusable Commerce & Data related text styles used throughout the interface.
							</p>
						</div>

						<div class="grid gap-8 md:grid-cols-2">

							<!-- Data Timer -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
									Data Timer
								</p>

								<p class="[font-family:'Orbitron'] text-xl font-bold tracking-[0.1em] text-slate-100">
									07 : 34 : 21
								</p>
							</div>

							<!-- Countdown Timer -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
									Countdown Timer
								</p>
								<p class="[font-family:'Orbitron'] mt-1 text-lg font-bold tracking-[0.12em] text-amber-400">
									02D : 11H : 48M
								</p>
							</div>
							<!-- Price Primary -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
									Price Primary
								</p>

								<p class="[font-family:'Inter'] text-4xl font-bold leading-none tracking-[-0.06em] text-slate-200">
									$249.99
								</p>
							</div>

							<!-- Compare Price -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
									Compare Price
								</p>

								<p class="[font-family:'Inter'] text-base leading-none text-slate-500 line-through">
									$299.99
								</p>
							</div>

							<!-- Savings Text -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
									Savings Text
								</p>

								<p class="[font-family:'Inter'] text-base font-medium text-[#3fc75d]">
									You Save $50.00 (17%)
								</p>
							</div>


					
						</div>
						</section>

					<!-- Body Copy Assets -->
					<section class="space-y-8">
						<div class="space-y-2">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Body Copy Assets
							</p>
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
									Base
								</p>

							<p class="text-base leading-relaxed text-slate-400">
								Reusable paragraph and informational text styles used throughout the interface.
							</p>
						</div>

						<div class="grid gap-8 md:grid-cols-2">

							<!-- Muted -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
									Muted
								</p>

								<p class="text-sm leading-relaxed text-slate-400">
									Used for standard supporting content, descriptions, and helper text.
								</p>
							</div>

							<!-- Prominent -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
									Prominent
								</p>

								<p class="text-base leading-relaxed text-slate-300">
									Used for featured supporting copy in hero sections and marketing moments.
								</p>
							</div>

							<!-- Quiet -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
									Quiet
								</p>

								<p class="text-base leading-relaxed text-slate-500">
									Used for notes, metadata support, and de-emphasized informational text.
								</p>
							</div>

							<!-- Overlay -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
									Overlay
								</p>

								<p class="text-base leading-relaxed text-white">
									Used over dark imagery, overlays, and high-contrast visual surfaces.
								</p>
							</div>

						</div>
						</section>
			
				</div>
			</section>


    </main>

</layout>