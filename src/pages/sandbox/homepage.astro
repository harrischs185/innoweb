---
import Layout from '../../layouts/Layout.astro';
---

<Layout
title="Homepage Lab"
description="Internal design and component testing environment."
noindex={true}
>
	<main class="min-h-screen bg-black px-6 py-12 text-white md:px-12">
		<div class="mx-auto max-w-7xl space-y-24">

			<!-- Page Header -->
			<header class="space-y-3 border-b border-white/10 pb-8">
				<p class="text-xs uppercase tracking-[0.28em] text-amber-400">
					InnoWeb Homepage Design Lab
				</p>

				<h1 class="[font-family:'Druk'] text-6xl uppercase tracking-[0.06em] leading-[0.9] scale-y-90 skew-x-[-4deg] bg-gradient-to-b from-white via-slate-100 via-slate-300 to-slate-700 
								bg-clip-text shadow-lg text-transparent drop-shadow-[0_9px_0_rgba(0,0,0,0.9)] transition duration-300 hover:scale-105 hover:drop-shadow-[0_10px_0_rgba(0,0,0,0.85)]">
					Homepage Experimentation Framework
				</h1>

				<p class="max-w-3xl text-sm leading-relaxed text-slate-400 md:text-base">
					This sandbox is used to test homepage systems before they are promoted
					into production components. Each section includes a label, variant ID,
					experiment area, notes, and status.
				</p>
			</header>

			<!-- Hero Systems -->
			<section class="space-y-8">
				<div class="space-y-2">
					<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
						Hero Systems
					</p>

					<h2 class="[font-family:'Inter'] text-4xl font-bold leading-none tracking-[-0.06em] text-slate-200">
						Hero A — Collector Playground
					</h2>

					<p class="max-w-3xl text-sm leading-relaxed text-slate-400">
						Goal: Explore a high-energy homepage hero that blends sports-card excitement,
						premium trust, and immediate shopping action.
					</p>
				</div>

				<div class="relative overflow-hidden rounded-3xl border border-white/10 bg-[radial-gradient(circle_at_70%_40%,rgba(251,191,36,0.16),transparent_35%),linear-gradient(135deg,#020617_0%,#000_55%,#120a00_100%)] p-8 shadow-[0_0_45px_rgba(251,191,36,0.08)]">
					<div class="grid gap-8 lg:grid-cols-[1fr_0.9fr] lg:items-center">
						<div class="space-y-6">
							<div>
								<p class="mb-3 text-xs uppercase tracking-[0.28em] text-amber-400">
									Variant ID: Hero A
								</p>

								<h3 class="[font-family:'Druk'] text-6xl uppercase tracking-[0.06em] leading-[0.9] scale-y-90 skew-x-[-4deg] bg-gradient-to-b from-white via-slate-100 via-slate-300 to-slate-700 
								bg-clip-text shadow-lg text-transparent drop-shadow-[0_9px_0_rgba(0,0,0,0.9)] transition duration-300 hover:scale-105 hover:drop-shadow-[0_10px_0_rgba(0,0,0,0.85)]">
									The Ultimate
								</h3>

								<h3 class="[font-family:'RoadRage'] bg-gradient-to-b from-yellow-100 via-yellow-400 to-yellow-900 bg-clip-text text-6xl uppercase leading-none tracking-[-0.08em] text-transparent drop-shadow-[0_8px_0_rgba(0,0,0,0.75)] md:text-8xl">
									Playground
								</h3>

								<h3 class="[font-family:'Druk'] text-6xl uppercase tracking-[0.06em] leading-[0.9] scale-y-90 skew-x-[-4deg] bg-gradient-to-b from-white via-slate-100 via-slate-300 to-slate-700 
								bg-clip-text shadow-lg text-transparent drop-shadow-[0_9px_0_rgba(0,0,0,0.9)] transition duration-300 hover:scale-105 hover:drop-shadow-[0_10px_0_rgba(0,0,0,0.85)]">
									For Serious Collectors
								</h3>
							</div>

							<p class="max-w-xl text-base leading-relaxed text-slate-300">
								Premium cards. Unbeatable deals. Elite service.
							</p>

							<div class="flex flex-wrap gap-4">
								<a class="rounded-lg bg-amber-400 px-6 py-3 text-sm font-bold uppercase tracking-wide text-black transition hover:bg-amber-300" href="#">
									Shop New Arrivals
								</a>

								<a class="rounded-lg border border-amber-400/60 px-6 py-3 text-sm font-bold uppercase tracking-wide text-amber-300 transition hover:border-amber-300 hover:bg-amber-400/10" href="#">
									Bunker's Bargains
								</a>
							</div>
						</div>

						<div class="rounded-2xl border border-white/10 bg-black/45 p-8 text-center shadow-[0_0_35px_rgba(59,130,246,0.12)]">
							<p class="text-xs uppercase tracking-[0.25em] text-slate-500">
								Experiment Placeholder
							</p>

							<div class="mt-6 flex aspect-[4/3] items-center justify-center rounded-2xl border border-dashed border-amber-400/30 bg-white/5">
								<p class="max-w-xs text-sm text-slate-400">
									Hero image/card composition goes here.
								</p>
							</div>
						</div>
					</div>
				</div>

				<div class="grid gap-4 md:grid-cols-3">
					<div class="rounded-xl border border-white/10 bg-white/[0.03] p-4">
						<p class="text-xs uppercase tracking-[0.18em] text-slate-500">Notes</p>
						<p class="mt-2 text-sm text-slate-400">
							High-energy hero direction. Needs imagery, product composition, and mobile testing.
						</p>
					</div>

					<div class="rounded-xl border border-white/10 bg-white/[0.03] p-4">
						<p class="text-xs uppercase tracking-[0.18em] text-slate-500">Status</p>
						<p class="mt-2 text-sm text-amber-400">
							Exploring
						</p>
					</div>

					<div class="rounded-xl border border-white/10 bg-white/[0.03] p-4">
						<p class="text-xs uppercase tracking-[0.18em] text-slate-500">Promotion Path</p>
						<p class="mt-2 text-sm text-slate-400">
							If validated, extract into components/home/HeroPrimary.astro.
						</p>
					</div>
				</div>
			</section>

			<!-- Navigation Systems -->
			<section class="space-y-8 border-t border-white/10 pt-12">
				<div class="space-y-2">
					<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
						Navigation Systems
					</p>

					<h2 class="[font-family:'Inter'] text-4xl font-bold leading-none tracking-[-0.06em] text-slate-200">
						Nav A — Premium Collector Header
					</h2>

					<p class="max-w-3xl text-sm leading-relaxed text-slate-400">
						Goal: Explore the main header structure including brand, search, account,
						cart, and primary navigation.
					</p>
				</div>

				<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6">
					<div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
						<div>
							<p class="[font-family:'Inter'] text-2xl font-black tracking-[-0.04em] text-white">
								InnoAV
							</p>
							<p class="text-xs uppercase tracking-[0.18em] text-amber-400">
								Sports Collectables
							</p>
						</div>

						<div class="flex-1 rounded-full border border-white/15 bg-black/60 px-5 py-3 text-sm text-slate-500 lg:max-w-xl">
							Search for cards, players, teams, or sets...
						</div>

						<div class="flex gap-4 text-sm text-slate-300">
							<span>Account</span>
							<span>Cart</span>
						</div>
					</div>

					<nav class="mt-6 flex flex-wrap gap-5 border-t border-white/10 pt-5 text-xs font-bold uppercase tracking-wide text-slate-300">
						<a href="#">Shop</a>
						<a href="#">Players</a>
						<a href="#">New Arrivals</a>
						<a class="text-amber-400" href="#">Bunker's Bargains</a>
						<a href="#">Buy / Consign</a>
						<a href="#">Resources</a>
						<a href="#">About Us</a>
					</nav>
				</div>

				<p class="max-w-3xl text-sm text-slate-500">
					Notes: Header should eventually become sticky/responsive. Mobile collapse behavior
					is not solved in this variant.
				</p>
			</section>

			<!-- Sports Navigation Tiles -->
			<section class="space-y-8 border-t border-white/10 pt-12">
				<div class="space-y-2">
					<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
						Sports Navigation Tile Systems
					</p>

					<h2 class="[font-family:'Inter'] text-4xl font-bold leading-none tracking-[-0.06em] text-slate-200">
						Sports Tiles A — Category Gateway
					</h2>

					<p class="max-w-3xl text-sm leading-relaxed text-slate-400">
						Goal: Test reusable sports category cards using real HTML/CSS shells with
						AI-generated artwork or product imagery later.
					</p>
				</div>

				<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-6">
					{['Football', 'Basketball', 'Baseball', 'Hockey', 'Soccer', 'Sealed'].map((sport) => (
						<div class="group rounded-2xl border border-blue-400/25 bg-[linear-gradient(135deg,rgba(15,23,42,0.95),rgba(0,0,0,0.95))] p-4 transition hover:-translate-y-1 hover:border-amber-400/60 hover:shadow-[0_0_25px_rgba(251,191,36,0.12)]">
							<div class="mb-5 flex aspect-square items-center justify-center rounded-xl border border-white/10 bg-white/[0.04] text-xs uppercase tracking-[0.18em] text-slate-600">
								Image
							</div>

							<p class="[font-family:'Druk'] text-2xl uppercase leading-none tracking-[-0.04em] text-white">
								{sport}
							</p>

							<p class="mt-2 text-xs font-bold uppercase tracking-wide text-amber-400">
								Shop Now →
							</p>
						</div>
					))}
				</div>

				<p class="max-w-3xl text-sm text-slate-500">
					Notes: Use AI imagery for artwork, but keep text, hover behavior, links,
					and responsive layout as real frontend components.
				</p>
			</section>

			<!-- Trust / Credibility Systems -->
			<section class="space-y-8 border-t border-white/10 pt-12">
				<div class="space-y-2">
					<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
						Trust / Credibility Systems
					</p>

					<h2 class="[font-family:'Inter'] text-4xl font-bold leading-none tracking-[-0.06em] text-slate-200">
						Trust Strip A — Collector Confidence
					</h2>

					<p class="max-w-3xl text-sm leading-relaxed text-slate-400">
						Goal: Explore compact credibility statements that can sit under hero sections,
						near product rows, or in the footer.
					</p>
				</div>

				<div class="grid gap-4 md:grid-cols-4">
					{[
						['100% Authentic', 'Guaranteed'],
						['Fast & Secure', 'Shipping'],
						['Collector Trusted', 'Since Day One'],
						['Veteran Owned', 'Family Operated'],
					].map(([title, subtitle]) => (
						<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-5">
							<p class="text-2xl text-amber-400">◇</p>
							<p class="mt-3 text-sm font-bold uppercase text-white">{title}</p>
							<p class="text-xs text-slate-500">{subtitle}</p>
						</div>
					))}
				</div>

				<p class="max-w-3xl text-sm text-slate-500">
					Notes: Trust language should remain direct, grounded, and not over-marketed.
				</p>
			</section>

			<!-- CTA Systems -->
			<section class="space-y-8 border-t border-white/10 pt-12">
				<div class="space-y-2">
					<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
						CTA Systems
					</p>

					<h2 class="[font-family:'Inter'] text-4xl font-bold leading-none tracking-[-0.06em] text-slate-200">
						CTA A — Buy / Consign Split
					</h2>

					<p class="max-w-3xl text-sm leading-relaxed text-slate-400">
						Goal: Explore conversion blocks that drive users toward shopping,
						consignment, or bargain inventory.
					</p>
				</div>

				<div class="grid gap-4 md:grid-cols-3">
					<div class="rounded-3xl border border-amber-400/20 bg-amber-400/5 p-6">
						<h3 class="[font-family:'Druk'] text-3xl uppercase leading-none text-white">
							Shop New Arrivals
						</h3>
						<p class="mt-3 text-sm text-slate-400">
							Find fresh slabs, rookies, autos, sealed products, and featured drops.
						</p>
						<a class="mt-5 inline-block rounded-lg bg-amber-400 px-5 py-3 text-xs font-bold uppercase text-black" href="#">
							Shop Now
						</a>
					</div>

					<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6">
						<h3 class="[font-family:'RoadRage'] bg-gradient-to-b from-yellow-100 via-yellow-400 to-yellow-900 bg-clip-text text-5xl uppercase leading-none text-transparent">
							Bunker's Bargains
						</h3>
						<p class="mt-3 text-sm text-slate-400">
							Insane deals. Limited time only.
						</p>
						<a class="mt-5 inline-block rounded-lg border border-amber-400/50 px-5 py-3 text-xs font-bold uppercase text-amber-300" href="#">
							View Deals
						</a>
					</div>

					<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6">
						<h3 class="[font-family:'Druk'] text-3xl uppercase leading-none text-white">
							Buy / Consign
						</h3>
						<p class="mt-3 text-sm text-slate-400">
							Turn your cards into cash through a trusted collector-first process.
						</p>
						<a class="mt-5 inline-block rounded-lg border border-white/20 px-5 py-3 text-xs font-bold uppercase text-white" href="#">
							Learn More
						</a>
					</div>
				</div>
			</section>

			<!-- Featured Inventory Systems -->
			<section class="space-y-8 border-t border-white/10 pt-12">
				<div class="space-y-2">
					<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
						Featured Inventory Systems
					</p>

					<h2 class="[font-family:'Inter'] text-4xl font-bold leading-none tracking-[-0.06em] text-slate-200">
						Product Row A — New Arrivals
					</h2>

					<p class="max-w-3xl text-sm leading-relaxed text-slate-400">
						Goal: Test product card density, price hierarchy, and add-to-cart affordance.
					</p>
				</div>

				<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
					{[1, 2, 3, 4].map((item) => (
						<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
							<div class="flex aspect-[3/4] items-center justify-center rounded-xl border border-dashed border-white/15 bg-black/60 text-xs uppercase tracking-[0.2em] text-slate-600">
								Product
							</div>

							<p class="mt-4 text-sm font-medium text-slate-200">
								2023 Featured Card #{item}
							</p>

							<p class="mt-1 text-xs text-slate-500">
								PSA 10 GEM MINT
							</p>

							<p class="mt-3 text-xl font-bold text-white">
								${item === 1 ? '599.99' : item === 2 ? '219.99' : item === 3 ? '169.99' : '449.99'}
							</p>

							<button class="mt-4 w-full rounded-md border border-blue-400/50 py-2 text-xs font-bold uppercase text-slate-200 transition hover:border-amber-400/70 hover:text-amber-300">
								Add To Cart
							</button>
						</div>
					))}
				</div>
			</section>

			<!-- Widget Systems -->
			<section class="space-y-8 border-t border-white/10 pt-12">
				<div class="space-y-2">
					<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
						Widget Systems
					</p>

					<h2 class="[font-family:'Inter'] text-4xl font-bold leading-none tracking-[-0.06em] text-slate-200">
						Widget A — Deal Of The Day
					</h2>

					<p class="max-w-3xl text-sm leading-relaxed text-slate-400">
						Goal: Test compact promotional widgets using the numeric/data accent system.
					</p>
				</div>

				<div class="max-w-md rounded-3xl border border-white/10 bg-white/[0.03] p-6">
					<div class="flex items-start justify-between gap-4">
						<h3 class="[font-family:'Druk'] bg-gradient-to-b from-yellow-300 via-amber-500 to-amber-900 bg-clip-text text-3xl uppercase leading-none text-transparent">
							Deal Of The Day
						</h3>

						<div class="rounded-md border border-amber-400/40 px-3 py-1.5 shadow-[0_0_10px_rgba(251,191,36,0.14)]">
							<p class="[font-family:'Orbitron'] text-sm font-bold tracking-[0.1em] text-slate-100">
								07 : 34 : 21
							</p>
						</div>
					</div>

					<div class="mt-6 grid grid-cols-[0.9fr_1fr] gap-5">
						<div class="flex aspect-[3/4] items-center justify-center rounded-xl border border-dashed border-white/15 bg-black/60 text-xs uppercase tracking-[0.2em] text-slate-600">
							Card
						</div>

						<div>
							<p class="text-sm text-slate-200">
								2018 Prizm Josh Allen Rookie #205
							</p>

							<p class="mt-1 text-xs text-slate-500">
								PSA 10 GEM MINT
							</p>

							<div class="mt-4 flex items-end gap-2">
								<p class="text-3xl font-extrabold leading-none tracking-[-0.06em] text-slate-200">
									$249.99
								</p>

								<p class="text-sm leading-none text-slate-500 line-through">
									$299.99
								</p>
							</div>

							<p class="mt-2 text-sm font-medium text-[#3fc75d]">
								You Save $50.00 (17%)
							</p>
						</div>
					</div>
				</div>
			</section>

			<!-- Footer Systems -->
			<section class="space-y-8 border-t border-white/10 pt-12">
				<div class="space-y-2">
					<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
						Footer Systems
					</p>

					<h2 class="[font-family:'Inter'] text-4xl font-bold leading-none tracking-[-0.06em] text-slate-200">
						Footer A — Trust + Payments
					</h2>

					<p class="max-w-3xl text-sm leading-relaxed text-slate-400">
						Goal: Explore footer layout with trust messaging, resource links, and secure payment indicators.
					</p>
				</div>

				<footer class="rounded-3xl border border-white/10 bg-white/[0.03] p-8">
					<div class="grid gap-8 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
						<div>
							<p class="[font-family:'Inter'] text-2xl font-black tracking-[-0.04em] text-white">
								InnoAV
							</p>
							<p class="mt-3 max-w-xs text-sm leading-relaxed text-slate-400">
								Elevating the collecting experience through trust, transparency,
								and unmatched service.
							</p>
						</div>

						<div>
							<p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">Shop</p>
							<ul class="mt-3 space-y-2 text-sm text-slate-400">
								<li>New Arrivals</li>
								<li>Best Sellers</li>
								<li>Player Shop</li>
								<li>Sealed Products</li>
							</ul>
						</div>

						<div>
							<p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">Resources</p>
							<ul class="mt-3 space-y-2 text-sm text-slate-400">
								<li>Blog</li>
								<li>Price Guide</li>
								<li>Grading Guide</li>
								<li>Collecting 101</li>
							</ul>
						</div>

						<div>
							<p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">Secure Payments</p>
							<div class="mt-4 grid grid-cols-2 gap-2 text-center text-xs font-bold text-black">
								<span class="rounded bg-white px-3 py-2">VISA</span>
								<span class="rounded bg-white px-3 py-2">MC</span>
								<span class="rounded bg-white px-3 py-2">AMEX</span>
								<span class="rounded bg-white px-3 py-2">PAY</span>
							</div>
						</div>
					</div>
				</footer>
			</section>

		</div>
	</main>
</Layout>