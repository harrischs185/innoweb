---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
	<main class="min-h-screen bg-slate-950 px-8 py-12 text-white">
		<section class="mx-auto max-w-6xl">
			<p class="mb-3 text-sm uppercase tracking-[0.35em] text-amber-400">
				InnoWeb Typography Lab
			</p>

			<h1 class="text-6xl font-black uppercase tracking-tight">
				Collector Energy. Trusted Commerce.
			</h1>

			<p class="mt-6 max-w-3xl text-lg text-slate-300">
				This sandbox will be used to test fonts, gradients, glow effects,
				hover states, responsive scaling, and readability before anything
				moves into the production homepage.
			</p>

			<div class="mt-10 grid gap-6 md:grid-cols-2">
				<div class="rounded-2xl border border-white/10 bg-white/5 p-6">
					<h2 class="text-3xl font-bold uppercase">Hero Display</h2>
					<p class="mt-3 text-slate-300">
						Testing bold display typography for major homepage moments.
					</p>
				</div>

				<div class="rounded-2xl border border-white/10 bg-white/5 p-6">
					<h2 class="text-3xl font-bold uppercase">UI / Body Font</h2>
					<p class="mt-3 text-slate-300">
						Testing readable text for cards, buttons, navigation, and product content.
					</p>
				</div>
			</div>
		</section>
	</main>
</Layout>