---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
	<main class="min-h-screen bg-black px-12 py-12 text-white space-y-8">
		<section class="mx-auto max-w-6xl space-y-20">
			<p class="mb-3 text-sm uppercase tracking-[0.35em] text-amber-400">
				InnoWeb Typography Lab<br>
			</p>
			<div class="h-px w-full max-w-md bg-slate-400/40"></div>
			</section>
		<section class="space-y-4">
				<p class="text-xs uppercase tracking-[0.35em] text-slate-500">
					Hero / Promo Brush Font
				</p>
				<div class="relative block">
					<div class="absolute inset-0 z-0 rounded-full blur-3xl"></div>
						<div class="relative z-10">
							<h1 class="[font-family:'RoadRage'] text-6xl uppercase tracking-[-0.08em] leading-[0.9] rotate-[-1deg] bg-gradient-to-b from-yellow-100 via-yellow-400 via-amber-500 to-yellow-900 
								bg-clip-text shadow-lg text-transparent drop-shadow-[0_8px_0_rgba(0,0,0,0.75)] transition duration-300 hover:scale-105 hover:drop-shadow-[0_10px_0_rgba(0,0,0,0.85)]">
									Playground
								</h1>
							<h1 class="[font-family:'RoadRage'] mt-2 text-3xl uppercase tracking-[-0.06em] leading-none bg-gradient-to-b from-white via-slate-200 to-slate-500 
								bg-clip-text text-transparent drop-shadow-[0_6px_0_rgba(0,0,0,0.7)]">
									Bunker's Bargains
								</h1>
						</div>
					</div>
				</div>
				<p class="max-w-xl text-sm text-slate-400">
					Used sparingly for maximum-impact promotional moments.<br>
				</p>
				<div class="h-px w-full max-w-md bg-slate-400/40"></div>
			</section>
		<section class="space-y-4">			
				<p class="text-xs uppercase tracking-[0.35em] text-slate-500">
					Condensed Athletic Display Font
				</p>
				<div class="relative block">
					<div class="absolute inset-0 z-0 rounded-full bg-amber-500/25 blur-3xl"></div>
						<div class="relative z-10">
							<h1 class="[font-family:'Druk'] text-6xl uppercase tracking-[0.06em] leading-[0.9] scale-y-90 skew-x-[-4deg] bg-gradient-to-b from-white via-slate-100 via-slate-300 to-slate-700 
								bg-clip-text shadow-lg text-transparent drop-shadow-[0_9px_0_rgba(0,0,0,0.9)] transition duration-300 hover:scale-105 hover:drop-shadow-[0_10px_0_rgba(0,0,0,0.85)]">
									The Ultimate
								</h1>
							<h1 class="[font-family:'Druk'] text-4xl uppercase tracking-[0.08em] leading-[0.9] skew-x-[-4deg] bg-gradient-to-b from-yellow-300 via-amber-500 to-amber-900 
								bg-clip-text shadow-lg text-transparent drop-shadow-[0_9px_0_rgba(0,0,0,0.9)] transition duration-300 hover:scale-105 hover:drop-shadow-[0_10px_0_rgba(0,0,0,0.85)]">
									For Serious Collectors
								</h1>
						</div>
					</div>
				</div>
				<p class="max-w-xl text-sm text-slate-400">
					Strong, athletic, confident. Drives herarchy<br>
					and delivers a performance feel.<br>
				</p>
				<div class="h-px w-full max-w-md bg-slate-400/40"></div>
			</section>
		<section class="space-y-4">
				<p class="text-xs uppercase tracking-[0.35em] text-slate-500">
					UI / Navigation Sans Serif Font
				</p>
				<div class="relative block">
					<div class="text-xs uppercase tracking-[0.22em] text-slate-500"></div>
						<div class="relative z-10">
							<p class="[font-family:'Inter'] text-[1.8rem] leading-[0.84] font-[300] leading-tight tracking-[-0.02em] 	text-[#f1f1f1]/95">
									Premium cards.
							</p>
							<p class="[font-family:'Inter'] text-[1.8rem] leading-[0.84] font-[300] leading-tight tracking-[-0.02em] text-[#f1f1f1]/95">
									Unbeatable deals.
							</p>
							<p class="[font-family:'Inter'] text-[1.8rem] leading-[0.84] font-[300] leading-tight tracking-[-0.02em] text-[#d89b16]">
									Elite service.
							</p>
						</div>
					</div>
				</div>
				<p class="max-w-xl text-sm leading-relaxed text-slate-400">
					Clean, modern, highly readable.<br>
					Built for clarity across all devices.<br>
				</p>
				<div class="h-px w-full max-w-md bg-slate-400/40"></div>
			</section>
		<section class="mspace-y-4">
				<p class="text-xs uppercase tracking-[0.35em] text-slate-500">
					Numeric / Data Accent Font
				</p>
				<div class="space-y-2">
					<div class="inline-block rounded-md border border-amber-400/40 px-4 py-1.5 shadow-[0_0_10px_rgba(251,191,36,0.14)]">
						<p class="[font-family:'Orbitron'] text-xl font-bold tracking-[0.1em] text-slate-100">
							07 : 34 : 21
						</p>
					</div>

					<div class="flex items-end gap-2">
						<p class="[font-family:'Inter'] text-4xl font-bold leading-none tracking-[-0.06em] text-slate-200">
							$249.99
						</p>

						<p class="[font-family:'Inter'] text-base leading-none text-slate-500 line-through">
							$299.99
						</p>
					</div>

					<p class="[font-family:'Inter'] 
					text-base 
					font-medium 
					text-[#3fc75d]">
						You Save $50.00 (17%)
					</p>
				</div>
				<p class="max-w-xl text-sm text-slate-400">
					Clean, technical, and realiable.<br>
					Perfect for numbers, timers, and data.<br>
				</p>
				<div class="h-px w-full max-w-md bg-slate-400/40"></div>
			</section>
		<section class="space-y-4">
			<p class="[font-family:'Druk'] mt-6 max-w-3xl text-lg text-slate-300">
				High energy. Agressive.Unmistakable.  Used sparingly for maximum impact.
			</p>

			<div class="mt-10 grid gap-6 md:grid-cols-3">
				<div class="rounded-2xl border border-white/10 bg-white/5 p-6">
					<h2 class="text-3xl font-bold uppercase">Hero Display</h2>
					<p class="mt-3 text-slate-300">
						Testing bold display typography for major homepage moments.
					</p>
				</div>

				<div class="rounded-2xl border border-white/10 bg-white/5 p-6">
					<h2 class="text-3xl font-bold uppercase">UI / Body Font</h2>
					<p class="mt-3 text-slate-300">
						Testing readable text for cards, buttons, navigation, and product content.
					</p>
				</div>
				<div class="rounded-2xl border border-white/10 bg-white/5 p-6">
					<h2 class="text-3xl font-bold uppercase">T Belle's Box</h2>
					<p class="mt-3 text-slate-300">
						Learning about this stuff!!
					</p>
				</div>
			</div>
			</section>
	</main>
</Layout>