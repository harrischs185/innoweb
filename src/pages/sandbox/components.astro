---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
	<main class="min-h-screen bg-black px-6 py-12 text-white md:px-12">
		<div class="mx-auto max-w-7xl space-y-24">

			<header class="space-y-3 border-b border-white/10 pb-8">
				<p class="text-xs uppercase tracking-[0.28em] text-amber-400">
					InnoWeb Component Lab
				</p>

				<h1 class="[font-family:'Druk'] bg-gradient-to-b from-white via-slate-200 to-slate-600 bg-clip-text text-5xl uppercase leading-none tracking-[0.05em] text-transparent md:text-7xl">
					Reusable UI Component Sandbox
				</h1>

				<p class="max-w-3xl text-sm leading-relaxed text-slate-400 md:text-base">
					This sandbox isolates reusable UI patterns before they are promoted into production
					components. Each section tests visual behavior, spacing, hierarchy, and reuse potential.
				</p>
			</header>

			<!-- Buttons -->
			<section class="space-y-8">
				<div class="space-y-2">
					<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
						Component Group
					</p>

					<h2 class="[font-family:'Druk'] text-4xl uppercase leading-none tracking-[0.03em] text-slate-100">
						Buttons
					</h2>

					<p class="max-w-3xl text-sm leading-relaxed text-slate-400">
						Goal: Test primary, secondary, ghost, and danger/action button styles.
					</p>
				</div>

				<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6">
					<div class="flex flex-wrap gap-4">
						<button class="rounded-lg bg-amber-400 px-6 py-3 text-sm font-bold uppercase tracking-wide text-black transition hover:bg-amber-300">
							Primary CTA
						</button>

						<button class="rounded-lg border border-amber-400/60 px-6 py-3 text-sm font-bold uppercase tracking-wide text-amber-300 transition hover:border-amber-300 hover:bg-amber-400/10">
							Secondary CTA
						</button>

						<button class="rounded-lg border border-white/15 px-6 py-3 text-sm font-bold uppercase tracking-wide text-slate-200 transition hover:border-white/35 hover:bg-white/5">
							Ghost Button
						</button>

						<button class="rounded-lg bg-red-500/15 px-6 py-3 text-sm font-bold uppercase tracking-wide text-red-300 ring-1 ring-red-400/30 transition hover:bg-red-500/25">
							Urgent Deal
						</button>
					</div>
				</div>

				<p class="max-w-3xl text-sm text-slate-500">
					Notes: Primary buttons should remain rare and conversion-focused. Secondary buttons support exploration.
				</p>
			</section>

			<!-- Badges -->
			<section class="space-y-8 border-t border-white/10 pt-12">
				<div class="space-y-2">
					<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
						Component Group
					</p>

					<h2 class="[font-family:'Druk'] text-4xl uppercase leading-none tracking-[0.03em] text-slate-100">
						Badges
					</h2>

					<p class="max-w-3xl text-sm leading-relaxed text-slate-400">
						Goal: Test small status markers for products, deals, trust signals, and inventory labels.
					</p>
				</div>

				<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6">
					<div class="flex flex-wrap gap-3">
						<span class="rounded-full bg-amber-400 px-4 py-1.5 text-xs font-bold uppercase tracking-wide text-black">
							New Arrival
						</span>

						<span class="rounded-full border border-green-400/40 bg-green-500/10 px-4 py-1.5 text-xs font-bold uppercase tracking-wide text-green-400">
							In Stock
						</span>

						<span class="rounded-full border border-blue-400/40 bg-blue-500/10 px-4 py-1.5 text-xs font-bold uppercase tracking-wide text-blue-300">
							PSA 10
						</span>

						<span class="rounded-full border border-red-400/40 bg-red-500/10 px-4 py-1.5 text-xs font-bold uppercase tracking-wide text-red-300">
							Hot Deal
						</span>

						<span class="rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-bold uppercase tracking-wide text-slate-300">
							Verified
						</span>
					</div>
				</div>

				<p class="max-w-3xl text-sm text-slate-500">
					Notes: Badges should clarify status, not decorate everything.
				</p>
			</section>

			<!-- Panels -->
			<section class="space-y-8 border-t border-white/10 pt-12">
				<div class="space-y-2">
					<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
						Component Group
					</p>

					<h2 class="[font-family:'Druk'] text-4xl uppercase leading-none tracking-[0.03em] text-slate-100">
						Panels
					</h2>

					<p class="max-w-3xl text-sm leading-relaxed text-slate-400">
						Goal: Test reusable section containers for trust blocks, widgets, and content modules.
					</p>
				</div>

				<div class="grid gap-4 md:grid-cols-3">
					<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6">
						<p class="text-xs uppercase tracking-[0.22em] text-slate-500">Standard Panel</p>
						<h3 class="mt-3 text-xl font-bold text-white">Clean Container</h3>
						<p class="mt-2 text-sm text-slate-400">
							Low-noise surface for general content.
						</p>
					</div>

					<div class="rounded-3xl border border-amber-400/20 bg-amber-400/5 p-6 shadow-[0_0_35px_rgba(251,191,36,0.06)]">
						<p class="text-xs uppercase tracking-[0.22em] text-amber-500">Featured Panel</p>
						<h3 class="mt-3 text-xl font-bold text-white">Highlighted Moment</h3>
						<p class="mt-2 text-sm text-slate-400">
							Used for promotions, featured drops, and priority CTAs.
						</p>
					</div>

					<div class="rounded-3xl border border-blue-400/20 bg-blue-500/5 p-6 shadow-[0_0_35px_rgba(59,130,246,0.06)]">
						<p class="text-xs uppercase tracking-[0.22em] text-blue-300">Trust Panel</p>
						<h3 class="mt-3 text-xl font-bold text-white">Collector Confidence</h3>
						<p class="mt-2 text-sm text-slate-400">
							Good for safety, authenticity, and service messaging.
						</p>
					</div>
				</div>
			</section>

			<!-- Cards -->
			<section class="space-y-8 border-t border-white/10 pt-12">
				<div class="space-y-2">
					<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
						Component Group
					</p>

					<h2 class="[font-family:'Druk'] text-4xl uppercase leading-none tracking-[0.03em] text-slate-100">
						Cards
					</h2>

					<p class="max-w-3xl text-sm leading-relaxed text-slate-400">
						Goal: Test product, player, sport, and content card shells.
					</p>
				</div>

				<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
					<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
						<div class="flex aspect-[3/4] items-center justify-center rounded-xl border border-dashed border-white/15 bg-black/60 text-xs uppercase tracking-[0.2em] text-slate-600">
							Product
						</div>

						<p class="mt-4 text-sm font-medium text-slate-200">2023 Featured Rookie</p>
						<p class="mt-1 text-xs text-slate-500">PSA 10 GEM MINT</p>
						<p class="mt-3 text-xl font-bold text-white">$249.99</p>
					</div>

					<div class="rounded-2xl border border-blue-400/20 bg-[linear-gradient(135deg,rgba(15,23,42,0.95),rgba(0,0,0,0.95))] p-4 transition hover:-translate-y-1 hover:border-amber-400/60 hover:shadow-[0_0_25px_rgba(251,191,36,0.12)]">
						<div class="mb-5 flex aspect-square items-center justify-center rounded-xl border border-white/10 bg-white/[0.04] text-xs uppercase tracking-[0.18em] text-slate-600">
							Sport
						</div>
						<p class="[font-family:'Druk'] text-2xl uppercase leading-none tracking-[-0.04em] text-white">Football</p>
						<p class="mt-2 text-xs font-bold uppercase tracking-wide text-amber-400">Shop Now →</p>
					</div>

					<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
						<div class="flex aspect-square items-center justify-center rounded-xl border border-dashed border-white/15 bg-black/60 text-xs uppercase tracking-[0.2em] text-slate-600">
							Player
						</div>

						<p class="mt-4 text-sm font-bold text-slate-100">Josh Allen</p>
						<p class="mt-1 text-xs text-slate-500">QB · Buffalo Bills</p>
						<p class="mt-3 text-xs font-bold uppercase tracking-wide text-amber-400">View PlayerPulse →</p>
					</div>

					<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
						<p class="text-xs uppercase tracking-[0.2em] text-slate-500">Blog</p>
						<h3 class="mt-4 text-xl font-bold leading-tight text-white">
							How To Spot Undervalued Rookies
						</h3>
						<p class="mt-3 text-sm leading-relaxed text-slate-400">
							A short content card pattern for educational posts.
						</p>
						<p class="mt-5 text-xs font-bold uppercase tracking-wide text-amber-400">Read More →</p>
					</div>
				</div>
			</section>

			<!-- Pricing Displays -->
			<section class="space-y-8 border-t border-white/10 pt-12">
				<div class="space-y-2">
					<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
						Component Group
					</p>

					<h2 class="[font-family:'Druk'] text-4xl uppercase leading-none tracking-[0.03em] text-slate-100">
						Pricing Displays
					</h2>

					<p class="max-w-3xl text-sm leading-relaxed text-slate-400">
						Goal: Test price hierarchy, sale formatting, and savings visibility.
					</p>
				</div>

				<div class="grid gap-4 md:grid-cols-3">
					<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-5">
						<p class="text-xs uppercase tracking-[0.18em] text-slate-500">Standard Price</p>
						<p class="mt-3 text-4xl font-extrabold tracking-[-0.06em] text-slate-200">$249.99</p>
					</div>

					<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-5">
						<p class="text-xs uppercase tracking-[0.18em] text-slate-500">Sale Price</p>
						<div class="mt-3 flex items-end gap-2">
							<p class="text-4xl font-extrabold tracking-[-0.06em] text-slate-200">$249.99</p>
							<p class="text-base text-slate-500 line-through">$299.99</p>
						</div>
						<p class="mt-2 text-base font-medium text-[#3fc75d]">You Save $50.00 (17%)</p>
					</div>

					<div class="rounded-2xl border border-amber-400/20 bg-amber-400/5 p-5">
						<p class="text-xs uppercase tracking-[0.18em] text-amber-500">Bunker Deal</p>
						<p class="[font-family:'RoadRage'] mt-3 bg-gradient-to-b from-yellow-100 via-yellow-400 to-yellow-900 bg-clip-text text-5xl uppercase leading-none text-transparent">
							$49.99
						</p>
						<p class="mt-2 text-sm text-slate-500">Limited time pricing</p>
					</div>
				</div>
			</section>

			<!-- Countdown Widgets -->
			<section class="space-y-8 border-t border-white/10 pt-12">
				<div class="space-y-2">
					<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
						Component Group
					</p>

					<h2 class="[font-family:'Druk'] text-4xl uppercase leading-none tracking-[0.03em] text-slate-100">
						Countdown Widgets
					</h2>

					<p class="max-w-3xl text-sm leading-relaxed text-slate-400">
						Goal: Test timer styles for deals, drops, auctions, and limited promotions.
					</p>
				</div>

				<div class="flex flex-wrap gap-4">
					<div class="inline-block rounded-md border border-amber-400/40 px-4 py-1.5 shadow-[0_0_10px_rgba(251,191,36,0.14)]">
						<p class="[font-family:'Orbitron'] text-xl font-bold tracking-[0.1em] text-slate-100">
							07 : 34 : 21
						</p>
					</div>

					<div class="rounded-xl border border-white/10 bg-white/[0.03] px-5 py-3">
						<p class="text-xs uppercase tracking-[0.18em] text-slate-500">Drop Ends In</p>
						<p class="[font-family:'Orbitron'] mt-1 text-lg font-bold tracking-[0.12em] text-amber-400">
							02D : 11H : 48M
						</p>
					</div>
				</div>
			</section>

			<!-- Overlays -->
			<section class="space-y-8 border-t border-white/10 pt-12">
				<div class="space-y-2">
					<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
						Component Group
					</p>

					<h2 class="[font-family:'Druk'] text-4xl uppercase leading-none tracking-[0.03em] text-slate-100">
						Overlays
					</h2>

					<p class="max-w-3xl text-sm leading-relaxed text-slate-400">
						Goal: Test readable text overlays for image-heavy cards and hero sections.
					</p>
				</div>

				<div class="grid gap-4 md:grid-cols-3">
					<div class="relative overflow-hidden rounded-3xl border border-white/10 bg-[radial-gradient(circle_at_70%_30%,rgba(251,191,36,0.22),transparent_35%),linear-gradient(135deg,#111827,#000)] p-6">
						<div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black/90 to-transparent"></div>
						<div class="relative z-10 mt-32">
							<p class="text-xs uppercase tracking-[0.2em] text-amber-400">Featured Drop</p>
							<h3 class="[font-family:'Druk'] mt-2 text-3xl uppercase leading-none text-white">Sunday Heat</h3>
						</div>
					</div>

					<div class="relative overflow-hidden rounded-3xl border border-white/10 bg-[linear-gradient(135deg,#020617,#111827)] p-6">
						<div class="absolute inset-0 bg-black/45"></div>
						<div class="relative z-10">
							<p class="text-xs uppercase tracking-[0.2em] text-slate-400">Glass Overlay</p>
							<div class="mt-20 rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur-md">
								<p class="text-sm text-white">Readable content over image/video backgrounds.</p>
							</div>
						</div>
					</div>

					<div class="relative overflow-hidden rounded-3xl border border-white/10 bg-[radial-gradient(circle_at_center,rgba(59,130,246,0.2),transparent_45%),#000] p-6">
						<div class="absolute inset-0 bg-gradient-to-r from-black via-black/70 to-transparent"></div>
						<div class="relative z-10 max-w-[70%]">
							<p class="text-xs uppercase tracking-[0.2em] text-blue-300">Side Fade</p>
							<h3 class="[font-family:'Druk'] mt-2 text-3xl uppercase leading-none text-white">Player Pulse</h3>
							<p class="mt-2 text-sm text-slate-400">Useful for player and market feature sections.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- Navigation Systems -->
			<section class="space-y-8 border-t border-white/10 pt-12">
				<div class="space-y-2">
					<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
						Component Group
					</p>

					<h2 class="[font-family:'Druk'] text-4xl uppercase leading-none tracking-[0.03em] text-slate-100">
						Navigation Systems
					</h2>

					<p class="max-w-3xl text-sm leading-relaxed text-slate-400">
						Goal: Test header, tabs, filter bars, and compact navigation elements.
					</p>
				</div>

				<div class="space-y-6">
					<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6">
						<div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
							<div>
								<p class="text-2xl font-black tracking-[-0.04em] text-white">InnoAV</p>
								<p class="text-xs uppercase tracking-[0.18em] text-amber-400">Sports Collectables</p>
							</div>

							<div class="flex-1 rounded-full border border-white/15 bg-black/60 px-5 py-3 text-sm text-slate-500 lg:max-w-xl">
								Search cards, players, teams, or sets...
							</div>

							<div class="flex gap-4 text-sm text-slate-300">
								<span>Account</span>
								<span>Cart</span>
							</div>
						</div>
					</div>

					<div class="flex flex-wrap gap-3">
						{['All', 'Football', 'Basketball', 'Baseball', 'Hockey', 'Sealed'].map((tab, index) => (
							<button class={`rounded-full px-5 py-2 text-xs font-bold uppercase tracking-wide transition ${index === 0 ? 'bg-amber-400 text-black' : 'border border-white/15 text-slate-300 hover:border-amber-400/60 hover:text-amber-300'}`}>
								{tab}
							</button>
						))}
					</div>
				</div>
			</section>

		</div>
	</main>
</Layout>