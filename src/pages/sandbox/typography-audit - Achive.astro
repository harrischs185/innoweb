
---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
    <main class="min-h-screen bg-black px-18 py-12 text-white space-y-8">

			<!-- Typography Role Audit -->
			<section class="space-y-10 border-t border-white/10 pt-16">

					<!-- Hero Brush Assets-->
					<section class="space-y-8">
						<div class="space-y-2">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Hero Brush Assets
							</p>
								
							<p class="text-base leading-relaxed text-slate-400">
								Reusable RoadRage-style hero brush text elements used throughout the interface.
							</p>
						</div>

						<div class="grid gap-8 md:grid-cols-1">

							<!-- Hero Brush Primary -->



							
							<div class="space-y-2 ">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">Hero Brush Primary</p>
										<h1 class="type-brush-hero">
											Playground
										</h1>	
							</div>

							<!-- Hero Brush Secondary -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Hero Brush Secondary</p>
								<h1 class="type-brush-secondary">
									Bunker's Bargains
								</h1>
							</div>

							<!-- Brush Price Accent -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Brush Price Accent</p>
								<p class="type-brush-price">
									$49.99
								</p>
							</div>

						</div>
						</section>

					<!-- Druk Hero Assets-->
					<section class="space-y-8">
						<div class="space-y-2">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Druk Hero Assets
							</p>
								
							<p class="text-base leading-relaxed text-slate-400">
								Reusable Druk-style hero text elements used throughout the interface.
							</p>
						</div>

						<div class="grid gap-8 md:grid-cols-1">

							<!-- Druk Hero Emphasis -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">Druk Hero Emphasis</p>
								<h1 class="type-druk-hero">
									The Ultimate
								</h1>
							</div>

							<!-- Druk Hero Clean -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Druk Hero Clean</p>
								<h1 class="type-druk-clean">
									The Ultimate
								</h1>
							</div>

							<!-- Druk Gold Accent -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Druk Gold Accent</p>
								<h1 class="type-druk-gold">
									For Serious Collectors
								</h1>
							</div>

						</div>
						</section>

					<!-- UI Statement Assets-->
					<section class="space-y-8">
						<div class="space-y-2">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								UI Statement Assets
							</p>
								
							<p class="text-base leading-relaxed text-slate-400">
								Reusable UI Statement text styles used throughout the interface.
							</p>
						</div>

						<div class="grid gap-8 md:grid-cols-2">

							<!-- UI Statement Text 1 -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">UI Statement Text Polish</p>
								<p class="type-ui-statement">
									Premium cards.
								</p>
							</div>

							<!-- UI Statement Text 2 -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> UI Statement Gold Polish</p>
								<p class="type-ui-statement-gold">
									Elite service.
								</p>
							</div>

							<!-- UI Statement Text 3 -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> UI Statement Text Bold</p>
								<h3 class="type-ui-statement-bold">
									Motion should add energy, not noise.
								</h3>
							</div>
						</div>
						</section>

					<!-- Titling Assets-->
					<section class="space-y-8">
						<div class="space-y-2">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Titling Assets
							</p>
								
							<p class="text-base leading-relaxed text-slate-400">
								Reusable Titling text styles used throughout the interface.
							</p>
						</div>

						<div class="grid gap-8 md:grid-cols-2">

							<!-- Product Title -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">Product Title</p>
								<p class="type-product-title">
									Product Title
								</p>
							</div>

							<!-- Panel Title -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Panel Title</p>
								<p class="type-panel-title">
									Panel Title
								</p>
							</div>

							<!-- Section Title -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Section Title</p>
								<p class="type-section-title">
									Section Title
								</p>
							</div>

						</div>
						</section>

					<!-- Label Assets-->
					<section class="space-y-8">
						<div class="space-y-2">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Labeling Assets
							</p>
								
							<p class="text-base leading-relaxed text-slate-400">
								Reusable labeling text styles used throughout the interface.
							</p>
						</div>

						<div class="grid gap-8 md:grid-cols-2">

							<!-- Context Label -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">Context Label</p>
								<p class="type-context-label">
									Context Label
								</p>
							</div>

							<!-- Eyebrow Label -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Eyebrow Label</p>
								<p class="type-eyebrow-label">
									Eyebrow Label
								</p>
							</div>

							<!-- Metadata Label -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Metadata Label</p>
								<p class="type-metadata">
									Metadata Label
								</p>
							</div>

							<!-- Status Label -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Status Label</p>
								<p class="type-status-label">
									Status Label
								</p>
							</div>

						</div>
						</section>

					<!-- Action Assets-->
					<section class="space-y-8">
						<div class="space-y-2">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Action Assets
							</p>
								
							<p class="text-base leading-relaxed text-slate-400">
								Reusable Call to Action related text styles used throughout the interface.
							</p>
						</div>

						<div class="grid gap-8 md:grid-cols-2">

							<!-- Action Label -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Action Label</p>
								<button class="rounded-full px-5 py-2 type-action-label">
									Action Label
								</button>
							</div>

							<!-- CTA Label -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500"> Player CTA</p>
								<p class="type-cta-label">
									View PlayerPulse →
								</p>
							</div>

						</div>
						</section>

					<!-- Commerce/Data Assets-->		
					<section class="space-y-8">
						<div class="space-y-2">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Commerce/Data Assets
							</p>
								
							<p class="text-base leading-relaxed text-slate-400">
								Reusable Commerce & Data related text styles used throughout the interface.
							</p>
						</div>

						<div class="grid gap-8 md:grid-cols-2">

							<!-- Data Timer -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
									Data Timer
								</p>

								<p class="type-data-timer">
									07 : 34 : 21
								</p>
							</div>

							<!-- Countdown Timer -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
									Countdown Timer
								</p>
								<p class="type-countdown-timer">
									02D : 11H : 48M
								</p>
							</div>
							<!-- Price Primary -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
									Price Primary
								</p>
								<p class="type-price-primary">
									$249.99
								</p>
							</div>

							<!-- Compare Price -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
									Compare Price
								</p>

								<p class="type-price-compare">
									$299.99
								</p>
							</div>

							<!-- Savings Text -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
									Savings Text
								</p>

								<p class="type-price-savings">
									You Save $50.00 (17%)
								</p>
							</div>


					
						</div>
						</section>

					<!-- Body Copy Assets -->
					<section class="space-y-8">
						<div class="space-y-2">
							<p class="text-xs uppercase tracking-[0.35em] text-amber-400">
								Body Copy Assets
							</p>
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
									Base
								</p>

							<p class="type-body">
								Reusable paragraph and informational text styles used throughout the interface.
							</p>
						</div>

						<div class="grid gap-8 md:grid-cols-2">

							<!-- Prominent -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
									Prominent
								</p>

								<p class="type-body-prominent">
									Used for featured supporting copy in hero sections and marketing moments.
								</p>
							</div>

							<!-- Quiet -->
							<div class="space-y-2">
								<p class="text-base leading-relaxed text-slate-500">
									Quiet
								</p>

								<p class="type-body-quiet">
									Used for notes, metadata support, and de-emphasized informational text.
								</p>
							</div>

							<!-- Overlay -->
							<div class="space-y-2">
								<p class="text-xs uppercase tracking-[0.22em] text-slate-500">
									Overlay
								</p>

								<p class="type-body-overlay">
									Used over dark imagery, overlays, and high-contrast visual surfaces.
								</p>
							</div>

						</div>
						</section>
			
				</div>
			</section>


    </main>

</layout>