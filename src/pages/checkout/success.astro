---
import Layout from '../../layouts/Layout.astro';

const orderNumber = Astro.url.searchParams.get('order');
---

<Layout
  title="Checkout Submitted"
  description="Your checkout was submitted and is being confirmed."
  noindex={true}
>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="rounded-3xl border border-emerald-500/40 bg-slate-950/90 p-8 text-center shadow-[0_0_40px_rgba(0,0,0,0.35)]">
      <p class="type-context-label text-emerald-300">
        Checkout Submitted
      </p>

      <h1 class="type-section-title mt-3 text-white">
        Thanks - your checkout is being confirmed.
      </h1>

      {orderNumber && (
        <p class="mt-5 text-sm font-bold uppercase tracking-wide text-slate-300">
          Order: {orderNumber}
        </p>
      )}

      <p class="mx-auto mt-5 max-w-2xl text-sm leading-relaxed text-slate-300">
        Stripe has redirected you back to InnoWeb. CardFlow confirms payment
        and inventory status through the secure Stripe webhook, not this page.
      </p>

      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a
          href="/shop"
          class="inline-flex rounded-md bg-gradient-to-b from-amber-300 to-amber-500 px-6 py-3 text-xs font-black uppercase text-black transition hover:brightness-110"
        >
          Continue Shopping
        </a>

        <a
          href="/"
          class="inline-flex rounded-md border border-sky-500 px-6 py-3 text-xs font-black uppercase text-white transition hover:bg-sky-500/10"
        >
          Home
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { clearCart } from '../../lib/cartStorage';

  clearCart();
</script>