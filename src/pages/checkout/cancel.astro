---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Checkout Cancelled"
  description="Your checkout was cancelled or not completed."
  noindex={true}
>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="rounded-3xl border border-amber-500/40 bg-slate-950/90 p-8 text-center shadow-[0_0_40px_rgba(0,0,0,0.35)]">
      <p class="type-context-label text-amber-300">
        Checkout Not Completed
      </p>

      <h1 class="type-section-title mt-3 text-white">
        Your checkout was cancelled.
      </h1>

      <p
        id="checkout-cancel-order"
        class="mt-5 hidden text-sm font-bold uppercase tracking-wide text-slate-300"
      >
        Order: <span id="checkout-cancel-order-number"></span>
      </p>

      <p
        id="checkout-cancel-status"
        class="mx-auto mt-5 max-w-2xl text-sm leading-relaxed text-slate-300"
      >
        No payment was confirmed from this page. Checking checkout status...
      </p>

      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a
          href="/cart"
          class="inline-flex rounded-md bg-gradient-to-b from-amber-300 to-amber-500 px-6 py-3 text-xs font-black uppercase text-black transition hover:brightness-110"
        >
          Return To Cart
        </a>

        <a
          href="/shop"
          class="inline-flex rounded-md border border-sky-500 px-6 py-3 text-xs font-black uppercase text-white transition hover:bg-sky-500/10"
        >
          Continue Shopping
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { postCardFlow } from '../../lib/cardflowApi';

  type CheckoutCancelResponse = {
    ok: true;
    orderNumber: string;
    status: 'cancelled' | 'already_cancelled';
    reservationStatus: 'released' | 'already_released';
  };

  const statusElement = document.querySelector<HTMLElement>(
    '#checkout-cancel-status',
  );
  const orderElement = document.querySelector<HTMLElement>(
    '#checkout-cancel-order',
  );
  const orderNumberElement = document.querySelector<HTMLElement>(
    '#checkout-cancel-order-number',
  );

  const orderNumber = new URLSearchParams(window.location.search)
    .get('order')
    ?.trim();

  async function releaseCheckoutHold() {
    if (!statusElement) {
      return;
    }

    if (!orderNumber) {
      statusElement.textContent =
        'No payment was confirmed from this page. Your cart has not been cleared, but no order reference was provided for automatic checkout release.';
      return;
    }

    if (orderElement && orderNumberElement) {
      orderNumberElement.textContent = orderNumber;
      orderElement.classList.remove('hidden');
    }

    statusElement.textContent =
      'No payment was confirmed from this page. Releasing the checkout hold so your cart can be used again immediately.';

    try {
      const response = await postCardFlow<CheckoutCancelResponse>(
        '/checkout/cancel',
        {
          orderNumber,
        },
      );

      statusElement.textContent =
        response.status === 'already_cancelled'
          ? 'No payment was completed. This checkout was already cancelled, and your cart is still saved.'
          : 'No payment was completed. The checkout hold has been released, and your cart is still saved.';
    } catch (error) {
      console.error('Checkout cancellation failed', error);

      statusElement.textContent =
        'No payment was completed. Your cart is still saved, but the checkout hold could not be released automatically. The item may remain reserved until the checkout session expires.';
    }
  }

  releaseCheckoutHold();
</script>