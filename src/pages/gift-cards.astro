---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import SectionWrapper from '../components/layout/SectionWrapper.astro';
import { fetchCardFlow } from '../lib/cardflowApi';

type GiftCardOffering = {
  sku: string;
  title: string;
  description: string | null;
  amount: string;
  currency: string;
};

type GiftCardOfferingsResponse = {
  ok: true;
  offerings: GiftCardOffering[];
  termsVersion: string;
};

let response: GiftCardOfferingsResponse | null = null;
let loadError = false;

try {
  response = await fetchCardFlow<GiftCardOfferingsResponse>('/gift-cards/offerings');
} catch (error) {
  console.error('Gift card offerings could not be loaded.', error);
  loadError = true;
}

const offerings = response?.offerings ?? [];
const termsVersion = response?.termsVersion ?? '';
---

<Layout
  title="Gift Cards | InnoAV Sports Collectables"
  description="Send a digital InnoAV Sports Collectables gift card to the collector in your life."
  noindex={loadError || offerings.length === 0}
>
  <SectionWrapper spacing="tight" container="wide">
    <section class="overflow-hidden rounded-3xl border border-slate-800 bg-slate-950">
      <div class="grid gap-8 p-6 lg:grid-cols-[0.9fr_1.1fr] lg:p-8 xl:p-10">
        <div class="flex flex-col justify-center">
          <p class="type-context-label text-amber-400">Digital Gift Cards</p>
          <h1 class="type-druk-cleanclamp mt-3 text-white">Let Them Pick The Hit.</h1>
          <p class="mt-5 max-w-xl text-sm leading-relaxed text-slate-300 lg:text-base">
            Choose an amount, add a personal message, and we will deliver the gift card by email after payment is confirmed.
          </p>

          <div class="mt-6 grid gap-3 text-sm text-slate-300">
            <p>Digital delivery only. No physical card is mailed.</p>
            <p>No customer account is required to receive the gift card.</p>
            <p>Gift card redemption will be added to InnoAV checkout during the next commerce slice.</p>
          </div>
        </div>

        <div class="rounded-2xl border border-amber-400/30 bg-gradient-to-br from-amber-400/15 via-slate-950 to-black p-6 shadow-[0_0_40px_rgba(245,158,11,0.10)]">
          {loadError || offerings.length === 0 ? (
            <div role="alert" class="rounded-xl border border-rose-500/40 bg-rose-500/10 p-5 text-sm leading-relaxed text-rose-100">
              Gift card purchasing is temporarily unavailable. Please try again later or continue shopping the catalog.
              <div class="mt-4">
                <a href="/shop" class="font-black uppercase text-amber-300 hover:text-amber-200">Shop Cards</a>
              </div>
            </div>
          ) : (
            <form id="gift-card-purchase-form" data-terms-version={termsVersion} novalidate>
              <fieldset>
                <legend class="type-context-label text-amber-400">Choose An Amount</legend>
                <div class="mt-3 grid gap-3 sm:grid-cols-3">
                  {offerings.map((offering, index) => (
                    <label class="cursor-pointer">
                      <input
                        class="peer sr-only"
                        type="radio"
                        name="offeringSku"
                        value={offering.sku}
                        checked={index === 0}
                      />
                      <span class="block rounded-xl border border-slate-700 bg-black/40 p-4 text-center text-lg font-black text-white transition peer-checked:border-amber-400 peer-checked:bg-amber-400/15 peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-amber-300">
                        ${Number(offering.amount).toFixed(0)}
                      </span>
                    </label>
                  ))}
                </div>
              </fieldset>

              <div class="mt-6 grid gap-4 sm:grid-cols-2">
                <label class="text-sm font-bold text-slate-200">
                  Your name
                  <input class="mt-2 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-3 text-white outline-none focus:border-amber-400" name="senderName" maxlength="100" autocomplete="name" required />
                </label>
                <label class="text-sm font-bold text-slate-200">
                  Your email
                  <input class="mt-2 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-3 text-white outline-none focus:border-amber-400" name="purchaserEmail" type="email" maxlength="320" autocomplete="email" required />
                </label>
                <label class="text-sm font-bold text-slate-200">
                  Recipient name
                  <input class="mt-2 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-3 text-white outline-none focus:border-amber-400" name="recipientName" maxlength="100" required />
                </label>
                <label class="text-sm font-bold text-slate-200">
                  Recipient email
                  <input class="mt-2 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-3 text-white outline-none focus:border-amber-400" name="recipientEmail" type="email" maxlength="320" autocomplete="off" required />
                </label>
                <label class="text-sm font-bold text-slate-200 sm:col-span-2">
                  Confirm recipient email
                  <input class="mt-2 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-3 text-white outline-none focus:border-amber-400" name="recipientEmailConfirmation" type="email" maxlength="320" autocomplete="off" required />
                </label>
                <label class="text-sm font-bold text-slate-200 sm:col-span-2">
                  Personal message <span class="font-normal text-slate-500">(optional, 500 characters)</span>
                  <textarea class="mt-2 min-h-28 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-3 text-white outline-none focus:border-amber-400" name="message" maxlength="500"></textarea>
                </label>
              </div>

              <label class="mt-5 flex items-start gap-3 text-sm leading-relaxed text-slate-300">
                <input class="mt-1 h-4 w-4 accent-amber-400" type="checkbox" name="termsAccepted" required />
                <span>I understand this is a digital stored-value gift card delivered by email, is not redeemable for cash except where required by law, and cannot currently be used to purchase another gift card.</span>
              </label>

              <div id="gift-card-form-error" tabindex="-1" class="mt-4 hidden rounded-lg border border-rose-500/40 bg-rose-500/10 p-3 text-sm text-rose-100" role="alert" aria-live="polite"></div>

              <button id="gift-card-submit" type="submit" class="mt-5 inline-flex w-full items-center justify-center rounded-md bg-gradient-to-b from-amber-300 to-amber-500 px-5 py-3 text-sm font-black uppercase text-black transition hover:brightness-110 disabled:cursor-not-allowed disabled:opacity-60">
                Continue To Secure Checkout
              </button>
            </form>
          )}
        </div>
      </div>
    </section>
  </SectionWrapper>
</Layout>

<script>
  import { CardFlowApiError, postCardFlow } from '../lib/cardflowApi';

  type PurchaseResponse = {
    ok: true;
    purchaseId: string;
    checkoutUrl: string;
  };

  const form = document.querySelector<HTMLFormElement>('#gift-card-purchase-form');
  const submitButton = document.querySelector<HTMLButtonElement>('#gift-card-submit');
  const errorBox = document.querySelector<HTMLElement>('#gift-card-form-error');
  let purchaseRequestId = crypto.randomUUID();

  function showError(message: string) {
    if (!errorBox) return;
    errorBox.textContent = message;
    errorBox.classList.remove('hidden');
    errorBox.focus();
  }

  function apiBody(error: unknown): { code?: string; message?: string | string[] } | null {
    if (error instanceof CardFlowApiError && typeof error.body === 'object' && error.body) {
      return error.body as { code?: string; message?: string | string[] };
    }

    return null;
  }

  function apiMessage(error: unknown): string {
    const body = apiBody(error);
    if (typeof body?.message === 'string') return body.message;
    if (Array.isArray(body?.message)) return body.message.join(' ');
    return 'Gift card checkout could not be created. Please review the form and try again.';
  }

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    errorBox?.classList.add('hidden');

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data = new FormData(form);
    const recipientEmail = String(data.get('recipientEmail') ?? '').trim();
    const recipientEmailConfirmation = String(data.get('recipientEmailConfirmation') ?? '').trim();

    if (recipientEmail.toLowerCase() !== recipientEmailConfirmation.toLowerCase()) {
      showError('Recipient email addresses do not match.');
      return;
    }

    if (submitButton) {
      submitButton.disabled = true;
      submitButton.textContent = 'Creating Checkout...';
    }

    try {
      const response = await postCardFlow<PurchaseResponse>('/gift-cards/purchases', {
        requestId: purchaseRequestId,
        offeringSku: String(data.get('offeringSku') ?? ''),
        purchaserEmail: String(data.get('purchaserEmail') ?? ''),
        recipientEmail,
        recipientEmailConfirmation,
        recipientName: String(data.get('recipientName') ?? ''),
        senderName: String(data.get('senderName') ?? ''),
        message: String(data.get('message') ?? ''),
        termsAccepted: data.get('termsAccepted') === 'on',
        termsVersion: form.dataset.termsVersion,
      });

      if (!response.ok || !response.checkoutUrl) {
        throw new Error('Gift card checkout response was incomplete.');
      }

      window.location.assign(response.checkoutUrl);
    } catch (error) {
      const errorCode = apiBody(error)?.code;
      if (
        errorCode === 'gift_card_checkout_creation_failed' ||
        errorCode === 'gift_card_request_already_used'
      ) {
        purchaseRequestId = crypto.randomUUID();
      }

      showError(apiMessage(error));
      if (submitButton) {
        submitButton.disabled = false;
        submitButton.textContent = 'Continue To Secure Checkout';
      }
    }
  });
</script>
