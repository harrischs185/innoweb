---

import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	return [
        { params: { slug: 'example' } },
		{ params: { slug: 'example-1' } },
        { params: { slug: 'example-2' } },
        { params: { slug: 'example-3' } },
        { params: { slug: 'example-4' } },
        { params: { slug: 'example-5' } },
        { params: { slug: 'example-6' } },
        { params: { slug: 'gift-cards' } },
	];
}

const { slug } = Astro.params;

const productConfig = {
	example: { title: 'Example Product' },
	'example-1': { title: 'Example Product 1' },
	'example-2': { title: 'Example Product 2' },
	'example-3': { title: 'Example Product 3' },
	'example-4': { title: 'Example Product 4' },
	'example-5': { title: 'Example Product 5' },
	'example-6': { title: 'Example Product 6' },
	'gift-cards': { title: 'Gift Cards' },
};

const config = productConfig[slug];
---


<Layout
title={config.title}
description={config.description}
noindex={false}
>
    <h1>Product Route Shell: {config.title}</h1>
    <p>Current product slug: {slug}</p>
</Layout>