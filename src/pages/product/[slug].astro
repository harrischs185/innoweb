---
import Layout from '../../layouts/Layout.astro';
import SectionWrapper from '../../components/layout/SectionWrapper.astro';

import ProductHeroSection from '../../components/products/ProductHeroSection.astro';
import ProductDetailsPanel from '../../components/products/ProductDetailsPanel.astro';
import ProductTrustPanel from '../../components/products/ProductTrustPanel.astro';

import { products } from '../../data/products';

export async function getStaticPaths() {
	return products.map((product) => ({
		params: { slug: product.slug },
	}));
}

const { slug } = Astro.params;
const product = products.find((item) => item.slug === slug);

if (!product) {
	return Astro.redirect('/shop');
}
---

<Layout
	title={`${product.title} | Sports Card Product | InnoAV Sports Collectables`}
	description={`View ${product.title}, pricing, details, and collector-focused product information from InnoAV Sports Collectables.`}
	noindex={false}
>
	<SectionWrapper spacing="tight" container="wide">
		<ProductHeroSection product={product} />
	</SectionWrapper>

	<SectionWrapper spacing="normal" container="wide">
		<ProductDetailsPanel product={product} />
	</SectionWrapper>

	<SectionWrapper spacing="normal" container="wide">
		<ProductTrustPanel />
	</SectionWrapper>
</Layout>