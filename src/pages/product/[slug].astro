---
import Layout from '../../layouts/Layout.astro';
import SectionWrapper from '../../components/layout/SectionWrapper.astro';

import ProductHeroSection from '../../components/products/ProductHeroSection.astro';
import ProductDetailsPanel from '../../components/products/ProductDetailsPanel.astro';
import ProductTrustPanel from '../../components/products/ProductTrustPanel.astro';

import { fetchCardFlow, type CardFlowDetailResponse, type CardFlowListResponse } from '../../lib/cardflowApi';
import {
	adaptProductDetail,
	type CardFlowProductDetail,
} from '../../lib/adapters/productDetailAdapter';
import type { CardFlowProductSummary } from '../../lib/adapters/productAdapter';

export async function getStaticPaths() {
	const response =
		await fetchCardFlow<CardFlowListResponse<CardFlowProductSummary>>('/products');

	return response.data.map((product) => ({
		params: { slug: product.slug },
	}));
}

const { slug } = Astro.params;

const response = await fetchCardFlow<CardFlowDetailResponse<CardFlowProductDetail>>(
	`/products/${slug}`,
);

if (!response.data) {
	return Astro.redirect('/shop');
}

const product = adaptProductDetail(response.data);
---

<Layout
	title={`${product.title} | Sports Card Product | InnoAV Sports Collectables`}
	description={`View ${product.title}, pricing, details, and collector-focused product information from InnoAV Sports Collectables.`}
	noindex={false}
>
	<SectionWrapper spacing="tight" container="wide">
		<ProductHeroSection product={product} />
	</SectionWrapper>

	<SectionWrapper spacing="normal" container="wide">
		<ProductDetailsPanel product={product} />
	</SectionWrapper>

	<SectionWrapper spacing="normal" container="wide">
		<ProductTrustPanel />
	</SectionWrapper>
</Layout>