---

<Layout title={config.name}>
	<SectionWrapper spacing="tight" container="wide">
		<SectionHeader
			eyebrow={config.eyebrow}
			title={config.name}
			subtitle={config.description}
			align="center"
		/>

		<div class="mt-8 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
			<div class="rounded-2xl border border-slate-800 bg-slate-950 p-6">
				<p class="text-sm uppercase tracking-wide text-amber-400">
					{config.sport}
				</p>

				<h2 class="mt-2 text-2xl font-bold text-white">
					Player Profile Shell
				</h2>

				<p class="mt-3 text-sm leading-relaxed text-slate-300">
					This area will eventually contain player-specific profile content, market notes, PlayerPulse highlights, and curated links.
				</p>
			</div>

			<div class="rounded-2xl border border-slate-800 bg-slate-950 p-6">
				<h2 class="text-xl font-bold text-white">
					Featured Inventory
				</h2>

				<p class="mt-3 text-sm text-slate-400">
					Player-specific product cards will hydrate here.
				</p>
			</div>
		</div>
	</SectionWrapper>
</Layout>