---
import Layout from '../../layouts/Layout.astro';
import SectionWrapper from '../../components/layout/SectionWrapper.astro';

import PlayerHeroSection from '../../components/players/PlayerHeroSection.astro';
import PlayerOverviewSection from '../../components/players/PlayerOverviewSection.astro';
import ShopProductGrid from '../../components/shop/ShopProductGrid.astro';

import {
	playerConfig,
	type PlayerKey,
} from '../../data/players';

export async function getStaticPaths() {
	return Object.keys(playerConfig).map((slug) => ({
		params: { slug },
	}));
}

const slug = Astro.params.slug as PlayerKey;

const player = {
	...playerConfig[slug],
	slug,
	href: `/players/${slug}`,
};
---

<Layout
	title={`${player.name} | ${player.sport} Cards & Collectibles | InnoAV Sports Collectables`}
	description={player.description}
	noindex={false}
>
	<SectionWrapper spacing="tight" container="wide">
		<PlayerHeroSection player={player} />
	</SectionWrapper>

	<SectionWrapper spacing="tight" container="wide">
		<PlayerOverviewSection player={player} />
	</SectionWrapper>

	<SectionWrapper spacing="tight" container="wide">
		<div id="player-inventory">
			<ShopProductGrid
				player={player.slug}
				title={`${player.name} Inventory`}
				eyebrow="Available Cards"
			/>
		</div>
	</SectionWrapper>
</Layout>