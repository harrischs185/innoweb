---
import Layout from '../../layouts/Layout.astro';
import SectionWrapper from '../../components/layout/SectionWrapper.astro';
import SectionHeader from '../../components/layout/SectionHeader.astro';
import PlayerNavigationSection from '../../components/players/PlayerNavigationSection.astro';

import {
	playerSportConfig,
	type PlayerSportKey,
} from '../../data/playerSports';
import {
	playerConfig,
	type PlayerKey,
} from '../../data/players';

export async function getStaticPaths() {
	return Object.keys(playerSportConfig).map((sport) => ({
		params: { sport },
	}));
}

const sport = Astro.params.sport as PlayerSportKey;
const config = playerSportConfig[sport];
const players = config.players.map((slug) => ({
	...playerConfig[slug as PlayerKey],
	slug,
	href: `/players/${slug}`,
}));
---
<Layout
title={config.title}
description={config.description}
noindex={false}
>
    <SectionWrapper spacing="tight" container="wide">
        <SectionHeader
            eyebrow="Players"
            title={config.title}
            align="center"
        />

        <PlayerNavigationSection players={players} />
    </SectionWrapper>
</Layout>