---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Shopping Cart"
  description="Review your cart and begin secure checkout."
  noindex={true}
>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="rounded-3xl border border-slate-800 bg-slate-950/90 p-6 shadow-[0_0_40px_rgba(0,0,0,0.35)] lg:p-8">
      <p class="type-context-label text-amber-400">
        Secure Checkout
      </p>

      <div class="mt-2 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <h1 class="type-section-title text-white">
            Shopping Cart
          </h1>

          <p class="mt-3 max-w-2xl text-sm leading-relaxed text-slate-300">
            Your cart is validated against CardFlow before checkout. Prices,
            availability, inventory status, and shipping come from the backend.
          </p>
        </div>

        <a
          href="/shop"
          class="inline-flex rounded-md border border-sky-500 px-5 py-3 text-xs font-black uppercase text-white transition hover:bg-sky-500/10"
        >
          Continue Shopping
        </a>
      </div>

      <div
        id="cart-alert"
        class="mt-6 hidden rounded-xl border p-4 text-sm font-bold"
        role="status"
        aria-live="polite"
      ></div>

      <div
        id="cart-loading"
        class="mt-8 rounded-2xl border border-slate-800 bg-black/35 p-6 text-slate-300"
        role="status"
        aria-live="polite"
      >
        Validating cart...
      </div>

      <div
        id="cart-empty"
        class="mt-8 hidden rounded-2xl border border-slate-800 bg-black/35 p-8 text-center"
      >
        <h2 class="type-panel-title text-white">
          Your cart is empty.
        </h2>

        <p class="mt-3 text-sm text-slate-300">
          Add a card from the shop to begin checkout.
        </p>

        <a
          href="/shop"
          class="mt-6 inline-flex rounded-md bg-gradient-to-b from-amber-300 to-amber-500 px-6 py-3 text-xs font-black uppercase text-black transition hover:brightness-110"
        >
          Browse Shop
        </a>
      </div>

      <div id="cart-content" class="mt-8 hidden grid gap-6 lg:grid-cols-[1fr_340px]">
        <div id="cart-items" class="grid gap-4"></div>

        <aside class="h-fit rounded-2xl border border-slate-800 bg-black/40 p-6">
          <p class="type-context-label text-amber-400">
            Order Summary
          </p>

          <div class="mt-5 space-y-3 text-sm">
            <div class="flex justify-between text-slate-300">
              <span>Subtotal</span>
              <span id="cart-subtotal" class="font-bold text-white">$0.00</span>
            </div>

            <div class="flex justify-between gap-4 text-slate-300">
              <span id="cart-shipping-label">Shipping</span>
              <span id="cart-shipping" class="font-bold text-white">$0.00</span>
            </div>

            <p
              id="cart-shipping-progress"
              class="hidden text-xs leading-relaxed text-amber-300"
            ></p>

            <div class="flex justify-between text-slate-300">
              <span>Tax</span>
              <span id="cart-tax" class="font-bold text-white">$0.00</span>
            </div>

            <div class="flex justify-between border-t border-slate-800 pt-3 text-slate-300">
              <span>Total</span>
              <span id="cart-total" class="font-black text-white">$0.00</span>
            </div>
          </div>

          <div
            id="cart-shipment-summary"
            class="mt-5 hidden rounded-xl border border-slate-800 bg-slate-950/70 p-4"
          >
            <p id="cart-shipment-count" class="text-xs font-black uppercase tracking-[0.12em] text-slate-300"></p>
            <div id="cart-parcel-breakdown" class="mt-3 flex flex-wrap gap-2"></div>
          </div>

          <div
            id="cart-shipping-protections"
            class="mt-4 hidden rounded-xl border border-sky-500/30 bg-sky-500/10 p-4"
          >
            <p class="text-xs font-black uppercase tracking-[0.12em] text-sky-200">
              Included Shipping Protections
            </p>
            <ul id="cart-protection-list" class="mt-3 space-y-2 text-xs leading-relaxed text-sky-100"></ul>
          </div>

          <div
            id="cart-shipping-review"
            class="mt-4 hidden rounded-xl border border-amber-500/40 bg-amber-500/10 p-4 text-xs leading-relaxed text-amber-100"
          ></div>

          <button
            id="checkout-button"
            type="button"
            class="mt-6 w-full rounded-md bg-gradient-to-b from-amber-300 to-amber-500 px-6 py-3 text-xs font-black uppercase text-black transition hover:brightness-110 disabled:cursor-not-allowed disabled:opacity-50"
            disabled
          >
            Checkout
          </button>

          <button
            id="clear-cart-button"
            type="button"
            class="mt-3 w-full rounded-md border border-slate-700 px-6 py-3 text-xs font-black uppercase text-slate-300 transition hover:border-red-400 hover:text-red-300"
          >
            Clear Cart
          </button>

          <p id="checkout-note" class="mt-4 text-xs leading-relaxed text-slate-500">
            Checkout redirects to Stripe. Payment and inventory status are
            confirmed by CardFlow after Stripe webhook processing.
          </p>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<script>
  import {
    CardFlowApiError,
    postCardFlow,
  } from '../lib/cardflowApi';
  import {
    clearCart,
    readCart,
    removeFromCart,
  } from '../lib/cartStorage';

  type CheckoutValidationItem = {
    sku: string;
    title?: string;
    quantity?: number;
    unitPrice?: string;
    lineTotal?: string;
    isBuyable?: boolean;
    commerceStatus?: string;
    commerceLabel?: string;
    reason?: string;
  };

  type CheckoutShippingMethod =
    | 'economy_letter'
    | 'standard_tracked'
    | 'known_large_item'
    | 'mixed'
    | 'free_threshold'
    | 'conservative_estimate';

  type CheckoutShippingPolicyResponse = {
    method: CheckoutShippingMethod;
    label: string;
    version: string;
    baseShippingAmount: string;
    freeShippingThreshold: string;
    remainingForFreeShipping: string;
    freeShippingQualified: boolean;
    parcelCounts: {
      economyLetter: number;
      standardTracked: number;
      knownLargeItem: number;
      customLarge: number;
      total: number;
    };
    premiumPackagingRequired: boolean;
    insuranceRequired: boolean;
    signatureRequired: boolean;
    signatureConfirmation: 'STANDARD' | null;
    shippingReviewRequired: boolean;
  };

  type CheckoutValidationResponse = {
    ok: boolean;
    items: CheckoutValidationItem[];
    subtotalAmount?: string;
    shippingAmount?: string;
    taxAmount?: string;
    totalAmount?: string;
    currency?: string;
    shippingPolicy?: CheckoutShippingPolicyResponse;
    errors?: {
      sku?: string;
      code?: string;
      message?: string;
    }[];
  };

  type CheckoutCreateResponse = {
    ok: boolean;
    orderNumber: string;
    checkoutUrl: string;
    stripeSessionId: string;
    reservationExpiresAt: string;
  };

  const loadingEl = document.getElementById('cart-loading');
  const emptyEl = document.getElementById('cart-empty');
  const contentEl = document.getElementById('cart-content');
  const itemsEl = document.getElementById('cart-items');
  const alertEl = document.getElementById('cart-alert');
  const subtotalEl = document.getElementById('cart-subtotal');
  const shippingLabelEl = document.getElementById('cart-shipping-label');
  const shippingEl = document.getElementById('cart-shipping');
  const shippingProgressEl = document.getElementById('cart-shipping-progress');
  const taxEl = document.getElementById('cart-tax');
  const totalEl = document.getElementById('cart-total');
  const shipmentSummaryEl = document.getElementById('cart-shipment-summary');
  const shipmentCountEl = document.getElementById('cart-shipment-count');
  const parcelBreakdownEl = document.getElementById('cart-parcel-breakdown');
  const shippingProtectionsEl = document.getElementById('cart-shipping-protections');
  const protectionListEl = document.getElementById('cart-protection-list');
  const shippingReviewEl = document.getElementById('cart-shipping-review');
  const checkoutButton = document.getElementById('checkout-button') as HTMLButtonElement | null;
  const clearCartButton = document.getElementById('clear-cart-button') as HTMLButtonElement | null;

  let hasRenderedCart = false;

  function escapeHtml(value: unknown) {
    return String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }

  function formatMoney(value: unknown, currency = 'USD') {
    const numericValue = Number(value);

    if (!Number.isFinite(numericValue)) {
      return String(value ?? '');
    }

    return new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency,
    }).format(numericValue);
  }

  function isRecord(value: unknown): value is Record<string, unknown> {
    return value !== null && typeof value === 'object';
  }

  function isCheckoutValidationResponse(
    value: unknown,
  ): value is CheckoutValidationResponse {
    return (
      isRecord(value) &&
      typeof value.ok === 'boolean' &&
      Array.isArray(value.items)
    );
  }

  function getErrorMessage(error: unknown, fallback: string) {
    if (error instanceof CardFlowApiError) {
      if (typeof error.body === 'string' && error.body.trim()) {
        return error.body;
      }

      if (isRecord(error.body)) {
        const message = error.body.message;

        if (typeof message === 'string' && message.trim()) {
          return message;
        }

        if (Array.isArray(message)) {
          const firstMessage = message.find(
            (entry): entry is string =>
              typeof entry === 'string' && Boolean(entry.trim()),
          );

          if (firstMessage) {
            return firstMessage;
          }
        }
      }
    }

    if (error instanceof Error && error.message) {
      return error.message;
    }

    return fallback;
  }

  function showAlert(message: string, tone: 'error' | 'info' = 'error') {
    if (!alertEl) {
      return;
    }

    alertEl.className = [
      'mt-6 rounded-xl border p-4 text-sm font-bold',
      tone === 'error'
        ? 'border-red-500/50 bg-red-500/10 text-red-200'
        : 'border-sky-500/50 bg-sky-500/10 text-sky-200',
    ].join(' ');

    alertEl.textContent = message;
    alertEl.classList.remove('hidden');
  }

  function hideAlert() {
    alertEl?.classList.add('hidden');
  }

  function setLoading(isLoading: boolean) {
    loadingEl?.classList.toggle('hidden', !isLoading);
  }

  function setCheckoutButton(disabled: boolean, label = 'Checkout') {
    if (!checkoutButton) {
      return;
    }

    checkoutButton.disabled = disabled;
    checkoutButton.textContent = label;
  }

  function resetShippingDetails() {
    shippingProgressEl?.classList.add('hidden');
    shipmentSummaryEl?.classList.add('hidden');
    shippingProtectionsEl?.classList.add('hidden');
    shippingReviewEl?.classList.add('hidden');

    if (shippingProgressEl) {
      shippingProgressEl.textContent = '';
    }

    if (shipmentCountEl) {
      shipmentCountEl.textContent = '';
    }

    if (parcelBreakdownEl) {
      parcelBreakdownEl.innerHTML = '';
    }

    if (protectionListEl) {
      protectionListEl.innerHTML = '';
    }

    if (shippingReviewEl) {
      shippingReviewEl.textContent = '';
    }
  }

  function showEmptyCart() {
    setLoading(false);
    hideAlert();
    setCheckoutButton(true);
    resetShippingDetails();
    emptyEl?.classList.remove('hidden');
    contentEl?.classList.add('hidden');
    hasRenderedCart = false;
  }

  function bindRemoveButtons() {
    document.querySelectorAll('[data-remove-sku]').forEach((button) => {
      button.addEventListener('click', () => {
        const sku = button.getAttribute('data-remove-sku');

        if (!sku) {
          return;
        }

        removeFromCart(sku);
        void loadCart();
      });
    });
  }

  function renderItems(items: CheckoutValidationItem[], currency: string) {
    if (!itemsEl) {
      return;
    }

    itemsEl.innerHTML = items
      .map((item) => {
        const validationUnavailable =
          item.commerceStatus === 'validation_unavailable';
        const statusClass = item.isBuyable
          ? 'border-emerald-500/40 bg-emerald-500/10 text-emerald-200'
          : validationUnavailable
            ? 'border-amber-500/40 bg-amber-500/10 text-amber-200'
            : 'border-red-500/40 bg-red-500/10 text-red-200';
        const authoritativePrice = item.lineTotal ?? item.unitPrice;
        const displayedPrice = authoritativePrice !== undefined
          ? formatMoney(authoritativePrice, currency)
          : 'Price unavailable';

        return `
          <article class="rounded-2xl border border-slate-800 bg-black/35 p-5">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="text-xs font-black uppercase tracking-[0.12em] text-slate-500">
                  SKU ${escapeHtml(item.sku)}
                </p>

                <h2 class="mt-2 text-lg font-black text-white">
                  ${escapeHtml(item.title ?? item.sku)}
                </h2>

                <div class="mt-3 inline-flex rounded-full border px-3 py-1 text-xs font-black uppercase ${statusClass}">
                  ${escapeHtml(item.commerceLabel ?? item.commerceStatus ?? 'Pending')}
                </div>

                ${
                  item.reason
                    ? `<p class="mt-3 text-sm ${validationUnavailable ? 'text-amber-200' : 'text-red-200'}">${escapeHtml(item.reason)}</p>`
                    : ''
                }
              </div>

              <div class="text-left sm:text-right">
                <p class="text-sm text-slate-400">Quantity ${escapeHtml(item.quantity ?? 1)}</p>
                <p class="mt-2 text-xl font-black text-white">
                  ${escapeHtml(displayedPrice)}
                </p>

                <button
                  type="button"
                  data-remove-sku="${escapeHtml(item.sku)}"
                  class="mt-4 rounded-md border border-slate-700 px-4 py-2 text-xs font-black uppercase text-slate-300 transition hover:border-red-400 hover:text-red-300"
                >
                  Remove
                </button>
              </div>
            </div>
          </article>
        `;
      })
      .join('');
  }

  function renderShippingPolicy(
    policy: CheckoutShippingPolicyResponse | undefined,
    currency: string,
  ) {
    resetShippingDetails();

    if (!policy) {
      return;
    }

    if (shippingProgressEl) {
      if (policy.freeShippingQualified) {
        const waivedAmount = Number(policy.baseShippingAmount);
        shippingProgressEl.textContent =
          Number.isFinite(waivedAmount) && waivedAmount > 0
            ? `Free shipping applied. ${formatMoney(policy.baseShippingAmount, currency)} in eligible shipping charges was waived.`
            : 'Free shipping has been applied.';
        shippingProgressEl.classList.remove('hidden');
      } else {
        const remainingForFreeShipping = Number(
          policy.remainingForFreeShipping,
        );

        if (
          Number.isFinite(remainingForFreeShipping) &&
          remainingForFreeShipping > 0
        ) {
          shippingProgressEl.textContent =
            `Add ${formatMoney(policy.remainingForFreeShipping, currency)} more for free shipping.`;
          shippingProgressEl.classList.remove('hidden');
        }
      }
    }

    const parcelBreakdown = [
      ['Economy Letter', policy.parcelCounts.economyLetter],
      ['Standard Tracked', policy.parcelCounts.standardTracked],
      ['Known Large Item', policy.parcelCounts.knownLargeItem],
      ['Custom Large', policy.parcelCounts.customLarge],
    ].filter(([, count]) => Number(count) > 0) as [string, number][];

    if (
      shipmentSummaryEl &&
      shipmentCountEl &&
      parcelBreakdownEl &&
      policy.parcelCounts.total > 0
    ) {
      shipmentCountEl.textContent =
        policy.parcelCounts.total === 1
          ? '1 Shipment'
          : `${policy.parcelCounts.total} Shipments`;

      parcelBreakdownEl.innerHTML = parcelBreakdown
        .map(([label, count]) => `
          <span class="rounded-full border border-slate-700 bg-black/30 px-3 py-1 text-xs font-bold text-slate-300">
            ${escapeHtml(count)} ${escapeHtml(label)}
          </span>
        `)
        .join('');

      shipmentSummaryEl.classList.remove('hidden');
    }

    const protections: string[] = [];

    if (policy.premiumPackagingRequired) {
      protections.push('Premium packaging included');
    }

    if (policy.insuranceRequired) {
      protections.push('Full-value insurance included');
    }

    if (policy.signatureRequired) {
      protections.push(
        policy.signatureConfirmation === 'STANDARD'
          ? 'Standard signature confirmation included'
          : 'Signature confirmation included',
      );
    }

    if (
      shippingProtectionsEl &&
      protectionListEl &&
      protections.length > 0
    ) {
      protectionListEl.innerHTML = protections
        .map((protection) => `<li>• ${escapeHtml(protection)}</li>`)
        .join('');
      shippingProtectionsEl.classList.remove('hidden');
    }

    if (shippingReviewEl && policy.shippingReviewRequired) {
      shippingReviewEl.textContent =
        'This shipment requires manual fulfillment review. The customer shipping charge shown here remains the authoritative checkout amount.';
      shippingReviewEl.classList.remove('hidden');
    }
  }

  function unavailableItemsFromLocalCart(
    reason: string,
  ): CheckoutValidationItem[] {
    return readCart().map((item) => ({
      sku: item.sku,
      quantity: item.quantity,
      isBuyable: false,
      commerceStatus: 'validation_unavailable',
      commerceLabel: 'Validation unavailable',
      reason,
    }));
  }

  function renderValidation(
    validation: CheckoutValidationResponse,
    notice?: string,
  ) {
    setLoading(false);

    const currency = validation.currency ?? 'USD';
    const localCart = readCart();
    const items = validation.items.length > 0
      ? validation.items
      : localCart.length > 0
        ? unavailableItemsFromLocalCart(
            validation.errors?.[0]?.message ??
              'CardFlow could not confirm current availability.',
          )
        : [];

    if (items.length === 0) {
      showEmptyCart();
      return;
    }

    hasRenderedCart = true;
    emptyEl?.classList.add('hidden');
    contentEl?.classList.remove('hidden');

    renderItems(items, currency);

    if (subtotalEl) {
      subtotalEl.textContent =
        validation.subtotalAmount !== undefined
          ? formatMoney(validation.subtotalAmount, currency)
          : 'Unavailable';
    }

    if (shippingLabelEl) {
      shippingLabelEl.textContent =
        validation.shippingPolicy?.label ?? 'Shipping';
    }

    if (shippingEl) {
      shippingEl.textContent =
        validation.shippingAmount !== undefined
          ? formatMoney(validation.shippingAmount, currency)
          : 'Unavailable';
    }

    if (taxEl) {
      taxEl.textContent =
        validation.taxAmount !== undefined
          ? formatMoney(validation.taxAmount, currency)
          : 'Unavailable';
    }

    if (totalEl) {
      totalEl.textContent =
        validation.totalAmount !== undefined
          ? formatMoney(validation.totalAmount, currency)
          : 'Unavailable';
    }

    renderShippingPolicy(validation.shippingPolicy, currency);
    setCheckoutButton(!validation.ok);

    if (!validation.ok) {
      showAlert(
        notice ??
          validation.errors?.[0]?.message ??
          'One or more cart items are not available for checkout.',
      );
    } else if (notice) {
      showAlert(notice);
    } else {
      hideAlert();
    }

    bindRemoveButtons();
  }

  async function loadCart(notice?: string) {
    const cart = readCart();

    if (cart.length === 0) {
      showEmptyCart();
      return;
    }

    setCheckoutButton(true, 'Validating...');
    setLoading(true);
    emptyEl?.classList.add('hidden');

    if (!hasRenderedCart) {
      contentEl?.classList.add('hidden');
    }

    try {
      const validation = await postCardFlow<CheckoutValidationResponse>(
        '/checkout/validate',
        { items: cart },
      );

      renderValidation(validation, notice);
    } catch (error) {
      console.error('Cart validation failed', error);

      if (
        error instanceof CardFlowApiError &&
        isCheckoutValidationResponse(error.body)
      ) {
        renderValidation(error.body, notice);
        return;
      }

      const message = getErrorMessage(
        error,
        'CardFlow could not confirm current cart availability.',
      );

      if (!hasRenderedCart) {
        renderValidation(
          {
            ok: false,
            items: unavailableItemsFromLocalCart(message),
            errors: [
              {
                code: 'validation_unavailable',
                message,
              },
            ],
          },
          message,
        );
        return;
      }

      setLoading(false);
      setCheckoutButton(true);
      showAlert(message);
    }
  }

  checkoutButton?.addEventListener('click', async () => {
    const cart = readCart();

    if (cart.length === 0) {
      showEmptyCart();
      return;
    }

    setCheckoutButton(true, 'Creating checkout...');

    try {
      const checkout = await postCardFlow<CheckoutCreateResponse>(
        '/checkout',
        { items: cart },
      );

      if (!checkout.ok || !checkout.checkoutUrl) {
        throw new Error('Checkout did not return a Stripe URL.');
      }

      window.location.assign(checkout.checkoutUrl);
    } catch (error) {
      console.error('Checkout creation failed', error);

      const message = getErrorMessage(
        error,
        'Checkout could not be created. CardFlow will revalidate the cart.',
      );

      await loadCart(message);
    }
  });

  clearCartButton?.addEventListener('click', () => {
    clearCart();
    showEmptyCart();
  });

  void loadCart();
</script>
