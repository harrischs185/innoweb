---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import SectionWrapper from '../components/layout/SectionWrapper.astro';
import ShopHeroSection from '../components/shop/ShopHeroSection.astro';
import ShopToolbar from '../components/shop/ShopToolbar.astro';
import ShopFilterSidebar from '../components/shop/ShopFilterSidebar.astro';
import ShopFeatureCards from '../components/shop/ShopFeatureCards.astro';
import ShopProductGrid from '../components/shop/ShopProductGrid.astro';

const collection = Astro.url.searchParams.get('collection');
---
<Layout
title="Shop Sports Cards & Collectibles"
description="Browse sports cards, autographs, graded cards, memorabilia, and featured collectibles across all categories."
noindex={false}
>
        <ShopHeroSection />

        <SectionWrapper spacing="tight">
            <ShopToolbar />
            <div class="grid gap-6 lg:grid-cols-[280px_1fr]">
                <ShopFilterSidebar />
                <div class="space-y-6">
                    <ShopFeatureCards />
                    <ShopProductGrid
                        collection={collection}
                        title={collection === 'featured-products' ? 'Featured QB Collection' : 'Shop All Cards'}
                        eyebrow={collection ? 'Featured Collection' : 'Browse Inventory'}
                    />
                </div>
            </div>
        </SectionWrapper>
</Layout>

<script>
        const shopScrollStorageKey = 'innoweb:shop-scroll-position';

        function saveShopScrollPosition() {
                sessionStorage.setItem(
                        shopScrollStorageKey,
                        String(window.scrollY),
                );
        }

        function bindShopScrollPreservation() {
                document
                        .querySelectorAll('[data-preserve-shop-scroll]')
                        .forEach((element) => {
                                if (
                                        element instanceof HTMLFormElement &&
                                        element.dataset.shopScrollBound !== 'true'
                                ) {
                                        element.dataset.shopScrollBound = 'true';
                                        element.addEventListener(
                                                'submit',
                                                saveShopScrollPosition,
                                        );
                                }

                                if (
                                        element instanceof HTMLAnchorElement &&
                                        element.dataset.shopScrollBound !== 'true'
                                ) {
                                        element.dataset.shopScrollBound = 'true';
                                        element.addEventListener(
                                                'click',
                                                saveShopScrollPosition,
                                        );
                                }
                        });
        }

        function restoreShopScrollPosition() {
                const storedPosition =
                        sessionStorage.getItem(shopScrollStorageKey);

                if (storedPosition === null) {
                        return;
                }

                sessionStorage.removeItem(shopScrollStorageKey);

                const scrollPosition = Number(storedPosition);

                if (!Number.isFinite(scrollPosition)) {
                        return;
                }

                requestAnimationFrame(() => {
                        requestAnimationFrame(() => {
                                window.scrollTo({
                                        top: scrollPosition,
                                        left: 0,
                                        behavior: 'auto',
                                });
                        });
                });
        }

        bindShopScrollPreservation();

        if (document.readyState === 'complete') {
                restoreShopScrollPosition();
        } else {
                window.addEventListener(
                        'load',
                        restoreShopScrollPosition,
                        { once: true },
                );
        }

        document.addEventListener(
                'astro:page-load',
                () => {
                        bindShopScrollPreservation();
                        restoreShopScrollPosition();
                },
        );
</script>