---
const items = [
	{
		label: '100% Authentic',
		copy: 'Guaranteed authentic or your money back.',
	},
	{
		label: 'Secure Shipping',
		copy: 'Safe, insured shipping on every order.',
	},
	{
		label: 'Top Grade Cards',
		copy: 'Carefully inspected and presented clearly.',
	},
	{
		label: 'Passion Driven',
		copy: 'Collector owned. Community focused.',
	},
];
---

<section aria-label="Buyer trust">
	<div class="grid gap-4 rounded-3xl border border-slate-800 bg-slate-950/85 p-5 md:grid-cols-2 xl:grid-cols-4">
		{items.map((item) => (
			<div class="rounded-2xl border border-slate-800 bg-black/35 p-4">
				<p class="type-context-label text-amber-400">
					{item.label}
				</p>

				<p class="mt-2 text-sm leading-relaxed text-slate-400">
					{item.copy}
				</p>
			</div>
		))}
	</div>
</section>