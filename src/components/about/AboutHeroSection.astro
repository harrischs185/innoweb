---

<section class="overflow-hidden rounded-3xl border border-slate-800 bg-slate-950">
	<div class="grid gap-8 p-6 lg:grid-cols-[0.9fr_1.1fr] lg:p-8 xl:p-10">
		<div class="flex flex-col justify-center">
			<p class="type-context-label text-amber-400">
				About InnoAV
			</p>

			<h1 class="type-druk-cleanclamp mt-3 text-white">
				Built By Collectors.
			</h1>

			<h2 class="type-brush-heroclamp mt-2 text-amber-400">
				For Collectors.
			</h2>

			<p class="mt-5 max-w-xl text-sm leading-relaxed text-slate-300 lg:text-base">
				InnoAV Sports Collectables is a collector-focused sports card shop built around trust, clean presentation, and a passion for the hobby.
			</p>

			<div class="mt-6 flex flex-wrap gap-3">
				<a
					href="/shop"
					class="inline-flex rounded-md bg-gradient-to-b from-amber-300 to-amber-500 px-5 py-3 text-xs font-black uppercase text-black transition hover:brightness-110"
				>
					Shop The Collection
				</a>

				<a
					href="mailto:innoavsports@outlook.com"
					class="inline-flex rounded-md border border-sky-500 px-5 py-3 text-xs font-black uppercase text-white transition hover:bg-sky-500/10"
				>
					Contact Us
				</a>
			</div>
		</div>

		<div class="rounded-2xl border border-amber-400/30 bg-black/40 p-6 shadow-[0_0_40px_rgba(245,158,11,0.10)]">
			<p class="type-context-label text-amber-400">
				Why Collectors Choose InnoAV
			</p>

			<div class="mt-5 grid gap-4">
				<div>
					<h3 class="type-panel-title text-white">100% Authentic</h3>
					<p class="mt-1 text-sm text-slate-400">
						Guaranteed authentic or your money back.
					</p>
				</div>

				<div>
					<h3 class="type-panel-title text-white">Secure Shipping</h3>
					<p class="mt-1 text-sm text-slate-400">
						Safe, insured shipping on every order.
					</p>
				</div>

				<div>
					<h3 class="type-panel-title text-white">Collector Owned</h3>
					<p class="mt-1 text-sm text-slate-400">
						Family operated and hobby focused.
					</p>
				</div>
			</div>
		</div>
	</div>
</section>