---
const { articles = [] } = Astro.props;
---

<section id="article-grid" aria-label="All blog articles">
	<div class="mb-5 flex items-end justify-between gap-4">
		<div>
			<p class="type-context-label text-amber-400">Latest From The Desk</p>
			<h2 class="type-section-title text-white">All Breakdowns</h2>
		</div>

		<p class="type-context-label text-slate-400">
			{articles.length} Articles
		</p>
	</div>

	<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
		{articles.map((article) => (
			<a
				href={`/blog/${article.slug}`}
				class="group rounded-2xl border border-slate-800 bg-slate-950/85 p-5 transition hover:-translate-y-0.5 hover:border-sky-500/70 hover:shadow-[0_0_24px_rgba(14,165,233,0.10)]"
			>
				<div class="flex items-center justify-between gap-3">
					<p class="type-context-label text-amber-400">{article.category}</p>

					<span class="rounded-full border border-slate-700 px-2 py-1 text-[10px] font-black uppercase tracking-wide text-slate-400">
						{article.status}
					</span>
				</div>

				<h3 class="type-panel-title mt-3 text-white">{article.title}</h3>

				<p class="mt-3 text-sm leading-relaxed text-slate-400">
					{article.excerpt}
				</p>

				<div class="mt-5 flex items-center justify-between">
					<p class="text-xs font-black uppercase tracking-wide text-sky-300">
						{article.readTime}
					</p>

					<p class="text-xs font-black uppercase tracking-wide text-amber-300 transition group-hover:translate-x-1">
						Read →
					</p>
				</div>
			</a>
		))}
	</div>
</section>