---
const { articles = [] } = Astro.props;

const featured = articles
	.filter((article) => article.status === 'Featured')
	.slice(0, 3);
---

<section id="featured-breakdown" aria-label="Featured blog content">
	<div class="mb-5 flex items-end justify-between gap-4">
		<div>
			<p class="type-context-label text-amber-400">Featured Breakdown</p>
			<h2 class="type-section-title text-white">Start Here</h2>
		</div>

		<a href="#article-grid" class="type-context-label text-amber-400 hover:text-amber-300">
			View All
		</a>
	</div>

	<div class="grid gap-4 md:grid-cols-3">
		{featured.map((article) => (
			<a
				href={`/blog/${article.slug}`}
				class="group rounded-2xl border border-slate-800 bg-slate-950/85 p-5 transition hover:-translate-y-0.5 hover:border-amber-400/70"
			>
				<p class="type-context-label text-amber-400">{article.category}</p>
				<h3 class="type-panel-title mt-2 text-white">{article.title}</h3>
				<p class="mt-3 text-sm leading-relaxed text-slate-400">{article.excerpt}</p>
				<p class="mt-5 text-xs font-black uppercase tracking-wide text-sky-300">
					{article.readTime}
				</p>
			</a>
		))}
	</div>
</section>