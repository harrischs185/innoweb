---
import type { boolean } from 'astro:schema';

type HeaderNavItem = {
	label: string;
	href: string;
};

interface Props {
	items?: HeaderNavItem[];
	debug?: boolean;
	class?: string; 
}


const {
	items = [
		{ label: 'SHOP', href: '/shop' },
		{ label: 'PLAYERS', href: '/players' },
        { label: 'NEW ARRIVALS', href: '/shop/new-arrivals' },
		{ label: 'BUY / CONSIGN', href: '/consign' },
        { label: 'ABOUT US', href: '/about' },
        { label: "BUNKER'S BREAKDOWN", href: '/blog' },
        { label: 'GIFT CARDS', href: '/gift-cards' },
	],
	debug = false,
	class: extraClass = '',
} = Astro.props;

const classes = [
	'hidden lg:flex',
	'items-center justify-center',
	'gap-4 xl:gap-6 2xl:gap-8',
	'py-3',
	extraClass,
].filter(Boolean).join(' ');
---

<nav class={classes} aria-label="Primary navigation">
	{items.map((item) => (
		<a
			href={item.href}
			class="type-body-prominent text-slate-300 transition hover:text-amber-400"
		>
			{item.label}
		</a>
	))}
</nav>