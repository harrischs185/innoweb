---
import heroBackground from '../../assets/images/homepage/hero/HeroBackground.png';
import heroForeground from '../../assets/images/homepage/hero/HeroForeground.webp';

const {
	eyebrow = 'Shop The Collection',
	title = 'The Cards You Want.',
	accent = 'The Deals You Love.',
	description = 'Authentic cards, premium slabs, collector-approved inventory, and new finds added as the hunt continues.',
	primaryHref = '/shop/new-arrivals',
	primaryLabel = 'Shop New Arrivals',
	secondaryHref = '/shop/graded',
	secondaryLabel = 'Shop Graded',
} = Astro.props;
---

<section
	class="relative overflow-hidden rounded-3xl border border-slate-800 bg-cover bg-center bg-no-repeat"
	style={`background-image: url(${heroBackground.src});`}
	aria-label="Shop hero"
>
	<div class="absolute inset-0 bg-gradient-to-r from-black via-black/70 to-black/20"></div>
	<div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_45%,rgba(245,158,11,0.22),transparent_38%)]"></div>

	<div class="relative grid min-h-[360px] gap-6 px-6 py-8 lg:grid-cols-[0.95fr_1.05fr] lg:px-8 lg:py-10 xl:px-10">
		<div class="flex flex-col justify-center">
			<div class="max-w-xl">
				<p class="type-context-label text-amber-400">
					Shop The Collection
				</p>

				<div class="mt-3 space-y-2">
					<h1 class="type-druk-heroclamp text-white">
						The Cards You Want.
					</h1>
					<h2 class="type-brush-heroclamp text-amber-400">
						The Deals You Love.
					</h2>
				</div>

				<p class="mt-5 max-w-lg text-sm leading-relaxed text-slate-200 lg:text-base">
					Authentic cards, premium slabs, collector-approved inventory, and new finds added as the hunt continues.
				</p>

				<div class="mt-6 flex flex-wrap gap-3">
					<a
						href="/shop/new-arrivals"
						class="inline-flex rounded-md bg-gradient-to-b from-amber-300 to-amber-500 px-5 py-3 text-xs font-black uppercase text-black transition hover:brightness-110"
					>
						Shop New Arrivals
					</a>

					<a
						href="/shop/graded"
						class="inline-flex rounded-md border border-sky-500 px-5 py-3 text-xs font-black uppercase text-white transition hover:bg-sky-500/10"
					>
						Shop Graded
					</a>
				</div>
			</div>
		</div>

		<div class="relative hidden items-end justify-center lg:flex">
			<img
				src={heroForeground.src}
				alt=""
				aria-hidden="true"
				class="max-h-[340px] w-full object-contain object-bottom drop-shadow-[0_0_40px_rgba(37,99,235,0.25)]"
			/>
		</div>
	</div>
</section>