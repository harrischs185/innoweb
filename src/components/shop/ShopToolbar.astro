---
const {
	resultCount = '1,248',
} = Astro.props;
---

<div class="mb-4 flex flex-col gap-3 rounded-xl border border-slate-800 bg-slate-950/80 p-3 sm:flex-row sm:items-center sm:justify-between">
	<div class="flex items-center gap-4">
		<p class="type-body-prominent uppercase text-white">
			Filter By
		</p>

		<button class="type-context-label text-sm text-amber-400 transition hover:text-amber-300">
			↻ Reset
		</button>

		<p class="type-context-label text-sm text-slate-400">
			{resultCount} Results
		</p>
	</div>

	<label class="flex items-center gap-2">
		<span class="type-context-label text-sm text-slate-400">Sort by</span>
		<select class="rounded-md border border-slate-700 bg-black px-3 py-2 text-sm text-slate-200 outline-none focus:border-amber-400">
			<option>Featured</option>
			<option>Newest</option>
			<option>Price: Low to High</option>
			<option>Price: High to Low</option>
		</select>
	</label>
</div>