---
import ProductCard from '../products/ProductCard.astro';
import { products } from '../../data/products';

const {
	category,
	limit,
	title = 'Shop All Cards',
	eyebrow = 'Browse Inventory',
} = Astro.props;

const filteredProducts = category
	? products.filter((product) =>
			product.category === category || product.tags.includes(category)
		)
	: products;

const visibleProducts = limit
	? filteredProducts.slice(0, limit)
	: filteredProducts;
---

<section aria-label="Shop products">
	<div class="mb-4 flex items-end justify-between gap-4">
		<div>
			<p class="type-context-label text-amber-400">Browse Inventory</p>
			<h2 class="type-section-title text-white">{title}</h2>
		</div>

		<p class="type-context-label text-slate-400">
			{visibleProducts.length} shown
		</p>
	</div>

	<div class="grid grid-cols-2 gap-4 md:grid-cols-3 xl:grid-cols-4">
		{visibleProducts.map((product) => (
			<ProductCard
				title={product.title}
				price={product.price}
				image={product.image}
				slug={product.slug}
			/>
		))}
	</div>
</section>