---
import ProductCard from '../products/ProductCard.astro';

import { fetchCardFlow, type CardFlowListResponse } from '../../lib/cardflowApi';
import {
	adaptProductCard,
	type CardFlowProductSummary,
} from '../../lib/adapters/productAdapter';

const {
	category,
	sport,
	player,
	limit,
	title = 'Shop All Cards',
	eyebrow = 'Browse Inventory',
} = Astro.props;

const queryParams = new URLSearchParams();

if (category) {
	queryParams.set('category', category);
}
if (sport) {
	queryParams.set('sport', sport);
}

if (player) {
	queryParams.set('player', player);
}

const productPath = queryParams.toString()
	? `/products?${queryParams.toString()}`
	: '/products';

const response =
	await fetchCardFlow<CardFlowListResponse<CardFlowProductSummary>>(productPath);

const products = response.data.map(adaptProductCard);

const visibleProducts = limit
	? products.slice(0, limit)
	: products;
---

<section aria-label="Shop products">
	<div class="mb-4 flex items-end justify-between gap-4">
		<div>
			<p class="type-context-label text-amber-400">{eyebrow}</p>
			<h2 class="type-section-title text-white">{title}</h2>
		</div>

		<p class="type-context-label text-slate-400">
			{visibleProducts.length} shown
		</p>
	</div>

	<div class="grid grid-cols-2 gap-4 md:grid-cols-3 xl:grid-cols-4">
		{visibleProducts.map((product) => (
			<ProductCard
				title={product.title}
				price={product.price}
				image={product.image}
				slug={product.slug}
			/>
		))}
	</div>
</section>