---
const {
	label = 'Football',
	href = '/shop/football',
	image = '',
	eyebrow = 'Explore',
	debug = false,
	class: extraClass = '',
} = Astro.props;

const debugClass = debug ? 'outline outline-1 outline-red-500' : '';

const classes = [
	'group relative overflow-hidden rounded-2xl border border-slate-800 bg-slate-950',
	'min-h-[120px] sm:min-h-[140px] lg:min-h-[150px]',
	'transition duration-300 hover:-translate-y-1 hover:border-amber-400/70 hover:shadow-[0_0_28px_rgba(245,158,11,0.16)]',
	debugClass,
	extraClass,
].filter(Boolean).join(' ');
---

<a href={href} class={classes} aria-label={`Shop ${label}`}>
	{image && (
		<img
			src={image}
			alt=""
			aria-hidden="true"
			class="absolute inset-0 h-full w-full object-cover object-top opacity-85 transition duration-300 group-hover:scale-105 group-hover:opacity-85"
		/>
	)}

	<div class="absolute inset-0 bg-gradient-to-t from-black via-black/45 to-transparent"></div>
	<div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_25%,rgba(245,158,11,0.18),transparent_35%)]"></div>

	<div class="relative flex h-full min-h-[180px] flex-col justify-end p-3 min-h-[130px] sm:min-h-[150px] lg:min-h-[165px]">
		{eyebrow && (
			<p class="type-utility-label text-amber-400">
				{eyebrow}
			</p>
		)}

		<h3 class="text-sm font-black uppercase tracking-wide text-white sm:text-base">
			{label}
		</h3>
	</div>
</a>