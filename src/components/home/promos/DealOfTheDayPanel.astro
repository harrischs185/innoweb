---
import PromoPanelShell from './PromoPanelShell.astro';
import dealImage from '../../../assets/images/homepage/promos/DealofTheDay.jpg';
import { fetchCardFlow } from '../../../lib/cardflowApi';
import {
  adaptFeaturedProducts,
  type CardFlowFeaturedProductsResponse,
} from '../../../lib/adapters/featuredProductAdapter';

const response = await fetchCardFlow<CardFlowFeaturedProductsResponse>(
  '/featured-products?collection=deal-of-the-day&limit=1',
);

const [deal] = adaptFeaturedProducts(response);

const {
	debug = false,
} = Astro.props;
---

<PromoPanelShell debug={debug}>
	<div class="grid h-full gap-5 p-5 md:grid-cols-[0.8fr_1fr] md:p-6">
		<div>
			<div class="flex items-center justify-between gap-4">
				<p class="type-promo-title">Deal of the Day</p>
			</div>

			<div class="relative min-h-[150px] overflow-hidden rounded-xl">
				<img
					src={deal?.image || dealImage.src}
					alt={deal?.title ?? "2023 Prizm Victor Wembanyana Black Shimmer 1/1 Rookie Card"}
					class="h-full w-full object-contain"
				/>
			</div>
		</div>

		<div class="flex flex-col justify-center">
				<div class="mb-3 w-fit rounded-md border border-sky-500 px-5 py-1 type-countdown-timer">
							07 : 34 : 21
				</div>

			<h3 class="text-xl font-semibold text-white">
				{deal?.title ?? '2023 Prizm Victor Wembanyana Black Shimmer 1/1 Rookie Card #205'}
			</h3>
			<p class="mt-1 text-sm uppercase tracking-wide text-slate-400">
				PSA 9 Mint
			</p>

			<div class="mt-4">
				<p class="text-3xl font-bold text-white">
					{deal?.price ?? '$1249.99'}
					<span class="ml-2 text-sm font-normal text-slate-500 line-through">$1299.99</span>
				</p>
				<p class="mt-1 text-sm text-green-400">
					You Save $50.00 (17%)
				</p>
			</div>

			<a href={deal?.href ?? '/product/example'} class="mt-6 inline-flex w-fit rounded-md border border-sky-500 px-5 py-2 text-sm font-bold uppercase tracking-wide text-white hover:bg-sky-500/10">
				Shop Deal
			</a>
		</div>
	</div>
</PromoPanelShell>