---
import PromoPanelShell from './PromoPanelShell.astro';
import featuredCollectionImage from '../../../assets/images/promos/FeaturedCollection.jpg';
const {
	debug = false,
} = Astro.props;
---

<PromoPanelShell debug={debug}>
	<div class="grid h-full gap-6 p-5 md:grid-cols-[0.8fr_1.2fr] md:p-6">
		<div class="flex flex-col justify-center">
			<p class="type-cta-label">Featured Collection</p>
			<h2 class="mt-2 text-2xl font-bold italic text-white md:text-3xl">
				2023-24 Panini Prizm
			</h2>
			<p class="mt-4 max-w-sm text-sm leading-relaxed text-slate-300">
				The hottest rookies. The brightest parallels. The future is now.
			</p>

			<a href="/shop/collections/prizm" class="mt-6 inline-flex w-fit rounded-md border border-sky-500 px-5 py-2 text-sm font-bold uppercase tracking-wide text-white hover:bg-sky-500/10">
				Shop Prizm
			</a>
		</div>

		<div class="relative min-h-[150px] overflow-hidden rounded-xl">
			<img
				src={featuredCollectionImage.src}
				alt="Featured Panini Prizm collection"
				class="h-full w-full object-contain"
			/>
		</div>
	</div>
</PromoPanelShell>