---
import PromoPanelShell from './PromoPanelShell.astro';

import { fetchCardFlow } from '../../../lib/cardflowApi';
import {
	adaptFeaturedCollection,
	type CardFlowFeaturedProductsResponse,
} from '../../../lib/adapters/featuredProductAdapter';
const {
	debug = false,
} = Astro.props;

const response = await fetchCardFlow<CardFlowFeaturedProductsResponse>(
	'/featured-products?collection=featured-products&limit=8'
);

const featuredCollection = adaptFeaturedCollection(response);
const primaryProduct = featuredCollection?.primaryProduct ?? null;
---

<PromoPanelShell debug={debug}>
	<div class="grid h-full gap-6 p-5 md:grid-cols-[0.8fr_1.2fr] md:p-6">
		<div class="flex flex-col justify-center">
			<p class="type-cta-label">Featured Collection</p>
			<h2 class="mt-2 text-2xl font-bold italic text-white md:text-3xl">
				{featuredCollection?.title ?? 'Featured Collection'}
			</h2>
			<p class="mt-4 max-w-sm text-sm leading-relaxed text-slate-300">
				{featuredCollection?.description ?? 'Curated featured products from CardFlow.'}
			</p>

			<a href={featuredCollection?.href ?? '/shop'} class="mt-6 inline-flex w-fit rounded-md border border-sky-500 px-5 py-2 text-sm font-bold uppercase tracking-wide text-white hover:bg-sky-500/10">
				{featuredCollection?.ctaLabel ?? 'Shop Collection'}
			</a>
		</div>

		<div class="relative min-h-[150px] overflow-hidden rounded-xl">
			{primaryProduct && (
				<img
					src={primaryProduct.image}
					alt={primaryProduct.title}
					class="h-full w-full object-contain"
				/>
			)}
		</div>
	</div>
</PromoPanelShell>