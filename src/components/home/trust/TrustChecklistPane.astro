---
import PromoPanelShell from '../promos/PromoPanelShell.astro';

const items = [
	'100% Authentic Guarantee',
	'Fast & Secure Shipping',
	'Elite Customer Service',
	'Collector Trusted',
];
---

<PromoPanelShell>
	<div class="flex h-full flex-col justify-center p-4">
		<h3 class="type-promo-title text-[clamp(0.85rem,1.1vw,1.05rem)]">
			Why Shop With Us?
		</h3>

		<ul class="mt-4 space-y-3 text-sm text-slate-200">
			{items.map((item) => (
				<li class="flex items-start gap-2">
					<span class="text-amber-400">✓</span>
					<span>{item}</span>
				</li>
			))}
		</ul>

		<a
			href="/about"
			class="mt-5 inline-flex w-fit rounded-md border border-sky-500 px-4 py-2 text-xs font-bold uppercase tracking-wide text-white hover:bg-sky-500/10"
		>
			Our Promise
		</a>
	</div>
</PromoPanelShell>