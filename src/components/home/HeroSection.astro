---
import SectionWrapper from '../layout/SectionWrapper.astro';
import ContentRail from '../layout/ContentRail.astro';
import HeroContent from './hero/HeroContent.astro';
import HeroMedia from './hero/HeroMedia.astro';
import HeroTrustBar from './hero/HeroTrustBar.astro';
import heroBackground from '../../assets/images/homepage/hero/HeroBackground.png';
import heroForeground from '../../assets/images/homepage/hero/HeroForeground.webp';

const {
	debug = false,
} = Astro.props;
---

<SectionWrapper spacing="flush" container="wide" debug={false}>
	<div
	class="overflow-hidden rounded-2xl border border-slate-800 bg-cover bg-center bg-no-repeat lg:hidden"
	style={`background-image: linear-gradient(180deg, rgba(2,6,23,0.88) 0%, rgba(3,7,18,0.65) 45%, rgba(2,6,23,0.9) 100%), url(${heroBackground.src});`}
	>
		<div class="p-4">
			<HeroContent />

			<HeroMedia
				src={heroForeground.src}
				alt="Featured sports cards and collectibles"
				debug={false}
				class="mt-4"
				imageClass="scale-[1.12] -translate-x-[2%] translate-y-1"
			/>

			<HeroTrustBar />
		</div>
	</div>

	<div
	class="hidden overflow-hidden rounded-3xl border border-slate-800 bg-cover bg-center bg-no-repeat lg:block"
	style={`background-image: linear-gradient(90deg, rgba(2,6,23,0.95) 0%, rgba(3,7,18,0.75) 45%, rgba(2,6,23,0.35) 100%), url(${heroBackground.src});`}
	>	
		<ContentRail split="hero" gap="hero" align="stretch" debug={false}
		class="px-6 py-8 lg:px-8 lg:py-10 xl:px-10 xl:py-12">
			<div slot="primary" class="flex h-full min-h-full flex-col lg:pl-4 xl:pl-6">
				<div class="space-y-3">
					<HeroContent />
					<HeroTrustBar />
				</div>
			</div>

			<div slot="secondary">
				<HeroMedia
					src={heroForeground.src}
					imageClass="
						max-h-[clamp(22rem,42vw,40rem)]
						scale-[1.02]
						translate-y-4

						md:scale-[1.04]
						md:translate-y-5

						lg:scale-[1.48]
						lg:translate-x-6
						lg:translate-y-16

						xl:scale-[1.42]
						xl:translate-x-5
						xl:translate-y-8
					"
				/>
			</div>
		</ContentRail>

		
	</div>
</SectionWrapper>