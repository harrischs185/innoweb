---
import SectionWrapper from '../layout/SectionWrapper.astro';
import ProductCarousel from '../products/ProductCarousel.astro';
import ProductCard from '../products/ProductCard.astro';

import { fetchCardFlow, type CardFlowListResponse } from '../../lib/cardflowApi';
import {
	adaptProductCard,
	type CardFlowProductSummary,
} from '../../lib/adapters/productAdapter';

const response = await fetchCardFlow<CardFlowListResponse<CardFlowProductSummary>>('/products');
const products = response.data.map(adaptProductCard);
---

<SectionWrapper spacing="flush" container="wide">
	<section aria-label="New arrivals">
		<div class="mb-5 flex items-center justify-between">
			<h2 class="type-promo-title">
				New Arrivals
			</h2>

			<a
				href="/shop/new-arrivals"
				class="text-sm font-bold uppercase tracking-wide text-amber-400 hover:text-amber-300"
			>
				View All
			</a>
		</div>

		<ProductCarousel>
			{products.map((product) => (
				<div class="w-[170px] shrink-0">
					<ProductCard
						title={product.title}
						price={product.price}
						image={product.image}
						slug={product.slug}
					/>
				</div>
			))}
		</ProductCarousel>
	</section>
</SectionWrapper>