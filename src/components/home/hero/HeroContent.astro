---
import HeroCTAGroup from './HeroCTAGroup.astro';

const {
	eyebrow = '',
	subtitle = 'Premium cards. Unbeatable deals. Elite service.',
} = Astro.props;
---

<div class="space-y-5 text-center lg:text-left">
	{eyebrow && <p class="type-context-label">{eyebrow}</p>}

	<div class="mx-auto max-w-[330px] space-y-1 lg:mx-0 lg:max-w-none">
		<h1 class="type-druk-heroclamp">The Ultimate</h1>
		<h1 class="type-brush-heroclamp">Playground</h1>
		<h1 class="type-druk-cleanclamp">For Serious Collectors</h1>
	</div>

	<p class="mx-auto max-w-sm text-sm leading-relaxed text-slate-200 lg:mx-0 lg:max-w-2xl lg:text-base">
		{subtitle}
	</p>

	<div class="flex min-w-0 flex-nowrap justify-center gap-2 lg:justify-start lg:gap-3">
		<HeroCTAGroup />
	</div>
</div>

