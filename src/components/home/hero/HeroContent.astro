---
import HeroCTAGroup from './HeroCTAGroup.astro';

const {
	eyebrow = '',
	subtitle = 'Premium cards. Unbeatable deals. Elite service.',
} = Astro.props;
---

<div class="space-y-15 text-center lg:text-left">
	{eyebrow && <p class="type-context-label">{eyebrow}</p>}

	<div class="mx-auto max-w-[360px] space-y-3 lg:mx-0 lg:max-w-none">
		<div class="mt-8 origin-center scale-[1.0] md:scale-[1.8] lg:origin-left lg:scale-[1.7]">
			<h1 class="type-druk-heroclamp">The Ultimate</h1>
			<h1 class="type-brush-heroclamp mt-1 lg:mt-2 xl:mt-3">Playground</h1>
			<h1 class="type-druk-cleanclamp mt-1 lg:mt-2 xl:mt-3">For Serious Collectors</h1>
		</div>
	</div>

	<p class="mx-auto max-w-sm text-sm leading-relaxed text-slate-200 lg:mx-0 lg:max-w-xl lg:text-base">
		{subtitle}
	</p>

	<div class="flex min-w-0 flex-nowrap justify-center gap-2 lg:justify-start lg:gap-3">
		<HeroCTAGroup />
	</div>
</div>

