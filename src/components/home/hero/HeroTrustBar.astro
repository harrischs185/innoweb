---
const items = [
	{
		icon: 'shield',
		title: '100% Authentic',
		subtitle: 'Guaranteed',
	},
	{
		icon: 'truck',
		title: 'Fast & Secure',
		subtitle: 'Shipping',
	},
	{
		icon: 'star',
		title: 'Top Rated',
		subtitle: 'By Collectors',
	},
	{
		icon: 'badge',
		title: 'Veteran Owned',
		subtitle: 'Family Operated',
	},
];
---

<div class="grid grid-cols-2 gap-4 border-t border-slate-800 pt-5 sm:grid-cols-4">
	{items.map((item) => (
		<div class="flex items-center gap-2">
			<div class="flex h-7 w-7 shrink-0 items-center justify-center text-amber-400">
				{item.icon === 'shield' && (
					<svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
						<path d="M12 3L19 6V11C19 15.5 16.2 19.7 12 21C7.8 19.7 5 15.5 5 11V6L12 3Z" stroke="currentColor" stroke-width="2" />
						<path d="M9 12L11 14L15 9.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				)}

				{item.icon === 'truck' && (
					<svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
						<path d="M3 7H15V17H3V7Z" stroke="currentColor" stroke-width="2" />
						<path d="M15 10H19L21 13V17H15V10Z" stroke="currentColor" stroke-width="2" />
						<circle cx="7" cy="18" r="1.5" stroke="currentColor" stroke-width="2" />
						<circle cx="18" cy="18" r="1.5" stroke="currentColor" stroke-width="2" />
					</svg>
				)}

				{item.icon === 'star' && (
					<svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
						<path d="M12 3L14.7 8.6L20.8 9.5L16.4 13.8L17.4 19.9L12 17L6.6 19.9L7.6 13.8L3.2 9.5L9.3 8.6L12 3Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
					</svg>
				)}

				{item.icon === 'badge' && (
					<svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
						<path d="M12 3L19 6V11C19 15.5 16.2 19.7 12 21C7.8 19.7 5 15.5 5 11V6L12 3Z" stroke="currentColor" stroke-width="2" />
						<path d="M12 8V14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
						<path d="M9 11H15" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
					</svg>
				)}
			</div>

			<div class="min-w-0 leading-tight">
				<p class="text-[0.65rem] font-bold uppercase tracking-[0.04em] text-white">
					{item.title}
				</p>
				<p class="text-[0.6rem] text-slate-400">
					{item.subtitle}
				</p>
			</div>
		</div>
	))}
</div>