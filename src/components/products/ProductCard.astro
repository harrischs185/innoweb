---
const {
	title = '2018 Prizm Josh Allen Rookie PSA 10',
	price = '$249.99',
	image = '',
	slug = 'example',
	href,
	debug = false,
	class: extraClass = '',
} = Astro.props;

const productHref = href ?? `/product/${slug}`;

const classes = [
	'group relative flex h-full flex-col overflow-hidden rounded-xl border border-slate-800 bg-slate-950',
	'transition duration-300 hover:border-sky-500/70 hover:shadow-[0_0_24px_rgba(37,99,235,0.18)]',
	extraClass,
].filter(Boolean).join(' ');
---

<article class={classes}>
	<a href={productHref} class="flex h-full flex-col">
		<div class="relative aspect-[3/4] overflow-hidden border-b border-slate-800 bg-black/40">
			{image && (
				<img
					src={image}
					alt={title}
					class="h-full w-full object-contain transition duration-300 group-hover:scale-105"
				/>
			)}
		</div>

		<div class="flex flex-1 flex-col p-3">
			<h3 class="line-clamp-3 text-xs font-medium leading-snug text-slate-100">
				{title}
			</h3>

			<p class="mt-3 text-lg font-bold text-white">
				{price}
			</p>

			<div class="mt-auto pt-3">
				<div class="inline-flex w-full items-center justify-center rounded-md border border-sky-500 px-3 py-2 text-[11px] font-bold uppercase tracking-wide text-white transition hover:bg-sky-500/10">
					View Product
				</div>
			</div>
		</div>
	</a>
</article>