---
const {
	split = 'balanced',
	gap = 'default',
	align = 'center',
	reverse = false,
	stackAt = 'md',
	debug = false,
	class: extraClass = '',
	primaryClass = '',
	secondaryClass = '',
} = Astro.props;

const splitClassMap = {
	balanced: 'md:grid-cols-2',
	primary: 'md:grid-cols-[1.35fr_0.65fr]',
	secondary: 'md:grid-cols-[0.65fr_1.35fr]',
	hero: 'content-rail--hero',
	media: 'md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]',
};

const gapClassMap = {
	none: 'gap-0',
	tight: 'gap-3 md:gap-4',
	default: 'gap-4 md:gap-6',
	loose: 'gap-6 md:gap-8 xl:gap-10',
	hero: 'gap-[clamp(0.5rem,1.5vw,1.5rem)]',
};

const alignClassMap = {
	start: 'items-start',
	center: 'items-center',
	end: 'items-end',
	stretch: 'items-stretch',
};

const stackClassMap = {
	sm: 'sm:grid',
	md: 'md:grid',
	lg: 'lg:grid',
};

const splitClass = splitClassMap[split] ?? splitClassMap.balanced;
const gapClass = gapClassMap[gap] ?? gapClassMap.default;
const alignClass = alignClassMap[align] ?? alignClassMap.center;
const stackClass = stackClassMap[stackAt] ?? stackClassMap.md;
const reverseClass = reverse ? 'md:[&>*:first-child]:order-2 md:[&>*:last-child]:order-1' : '';
const debugClass = debug ? 'layout-debug-inner' : '';

const classes = [
	'grid',
	'grid-cols-1',
	stackClass,
	splitClass,
	gapClass,
	alignClass,
	reverseClass,
	debugClass,
	extraClass,
].filter(Boolean).join(' ');

const childDebugClass = debug ? 'border border-cyan-400/70 bg-black/30' : '';
---

<div class={classes}>
	<div class={[childDebugClass, 'min-w-0', primaryClass].filter(Boolean).join(' ')}>
		<slot name="primary" />
	</div>

	<div class={[childDebugClass, 'min-w-0', secondaryClass].filter(Boolean).join(' ')}>
		<slot name="secondary" />
	</div>
</div>

<style>
	.content-rail--hero {
		grid-template-columns: 1fr;
	}

	@media (min-width: 768px) {
		.content-rail--hero {
			grid-template-columns:
				minmax(0, 1fr)
				minmax(20rem, clamp(22rem, 42vw, 44rem));
		}
	}
</style>