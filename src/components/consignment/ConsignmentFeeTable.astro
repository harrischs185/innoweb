---
import { consignmentFees } from '../../data/consignmentFees';
---

<section id="consignment-fees" aria-label="Consignment fees">
	<div class="overflow-hidden rounded-3xl border border-amber-400/30 bg-slate-950/90">
		<div class="border-b border-amber-400/20 px-6 py-5 text-center">
			<p class="type-context-label text-amber-400">
				Consignment Fees
			</p>

			<h2 class="type-section-title mt-2 text-white">
				Simple Rates. Clear Payouts.
			</h2>
		</div>

		<div class="overflow-x-auto">
			<table class="w-full min-w-[620px] text-left">
				<thead class="border-b border-slate-800 bg-black/40">
					<tr>
						<th class="px-5 py-4 text-xs font-black uppercase tracking-wide text-slate-300">
							Purchase Price
						</th>
						<th class="px-5 py-4 text-xs font-black uppercase tracking-wide text-slate-300">
							You Receive
						</th>
						<th class="px-5 py-4 text-xs font-black uppercase tracking-wide text-slate-300">
							Listing Fee
						</th>
					</tr>
				</thead>

				<tbody>
					{consignmentFees.map((row) => (
						<tr class="border-b border-slate-800/80 last:border-b-0">
							<td class="px-5 py-4 text-sm font-semibold text-white">
								{row.purchasePrice}
							</td>
							<td class="px-5 py-4 text-sm font-semibold text-amber-300">
								{row.youReceive}
							</td>
							<td class="px-5 py-4 text-sm text-slate-300">
								{row.listingFee}
							</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	</div>
</section>