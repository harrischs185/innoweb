---
const benefits = [
	{
		title: 'Maximum Exposure',
		copy: 'Your cards are presented across collector-focused storefront and marketplace workflows.',
	},
	{
		title: 'Fast & Easy',
		copy: 'Send the cards, provide the details, and let us handle the selling process.',
	},
	{
		title: 'Collector Focused',
		copy: 'Listings are built for people who understand the hobby, not generic liquidation traffic.',
	},
	{
		title: 'Clear Payouts',
		copy: 'Simple fee structure, transparent expectations, and a process designed to reduce uncertainty.',
	},
];
---

<section aria-label="Why consign with us">
	<div class="mb-5 text-center">
		<p class="type-context-label text-amber-400">
			Why Consign With Us
		</p>

		<h2 class="type-section-title mt-2 text-white">
			We Handle The Chaos
		</h2>

		<p class="mx-auto mt-3 max-w-2xl text-sm leading-relaxed text-slate-400 lg:text-base">
			Consignment should feel simple, trustworthy, and worth the effort.
		</p>
	</div>

	<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
		{benefits.map((benefit) => (
			<div class="rounded-2xl border border-slate-800 bg-slate-950/85 p-5 transition hover:-translate-y-0.5 hover:border-amber-400/60">
				<p class="type-panel-title text-white">
					{benefit.title}
				</p>

				<p class="mt-3 text-sm leading-relaxed text-slate-400">
					{benefit.copy}
				</p>
			</div>
		))}
	</div>
</section>