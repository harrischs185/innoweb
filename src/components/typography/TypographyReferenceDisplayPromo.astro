---

<section class="min-h-screen bg-black px-6 py-10 text-white md:px-10">
	<div class="mx-auto max-w-[1500px] rounded-3xl border border-amber-500/50 bg-slate-950 p-6 shadow-2xl md:p-10">
		<header class="mb-8 border-b border-slate-700 pb-6">
			<p class="type-context-label">Typography Library</p>
			<h1 class="type-druk-gold mt-3">Display / Promo Typography</h1>
			<p class="mt-4 max-w-3xl text-sm leading-relaxed text-slate-400 md:text-base">
				Reference sheet for the promoted display and promotional typography classes.
				Each visual example uses the actual class from <code>typography.css</code>.
			</p>
		</header>

		<div class="grid gap-4">
			<div class="hidden grid-cols-[280px_1fr_520px] gap-6 border-b border-slate-700 pb-3 text-xs font-bold uppercase tracking-[0.18em] text-amber-400 lg:grid">
				<div>Class</div>
				<div>Intended Use</div>
				<div>Visual Example</div>
			</div>

			{items.map((item) => (
				<article class="grid gap-4 rounded-2xl border border-slate-800 bg-slate-900/70 p-5 lg:grid-cols-[280px_1fr_520px] lg:items-center lg:gap-6">
					<div>
						<p class="mb-1 text-xs font-bold uppercase tracking-[0.16em] text-slate-500 lg:hidden">
							Class
						</p>
						<code class="text-sm text-sky-300 md:text-base">
							.{item.className}
						</code>
					</div>

					<div>
						<p class="mb-1 text-xs font-bold uppercase tracking-[0.16em] text-slate-500 lg:hidden">
							Intended Use
						</p>
						<p class="text-sm leading-relaxed text-slate-300 md:text-base">
							{item.use}
						</p>
					</div>

					<div class="overflow-hidden rounded-xl border border-slate-800 bg-black/60 p-4">
						<p class="mb-2 text-xs font-bold uppercase tracking-[0.16em] text-slate-500 lg:hidden">
							Visual Example
						</p>
						<div class={item.className}>
							{item.sample}
						</div>
					</div>
				</article>
			))}
		</div>
	</div>
</section>

