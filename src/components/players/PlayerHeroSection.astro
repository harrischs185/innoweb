---
const {
	player,
} = Astro.props;

const playerImage = player.image;
---

<section class="relative overflow-hidden rounded-3xl border border-slate-800 bg-slate-950">
	<div class="absolute inset-0 bg-[radial-gradient(circle_at_72%_42%,rgba(37,99,235,0.28),transparent_36%)]"></div>
	<div class="absolute inset-0 bg-gradient-to-r from-black via-slate-950/90 to-black/40"></div>

	<div class="relative grid min-h-[380px] gap-8 px-6 py-8 lg:grid-cols-[0.95fr_1.05fr] lg:px-8 lg:py-10 xl:px-10">
		<div class="flex flex-col justify-center">
			<p class="type-context-label text-amber-400">
				{player.sport} Collector Hub
			</p>

			<div class="mt-3 space-y-2">
				<h1 class="type-druk-heroclamp">
					{player.name}
				</h1>

				<p class="type-body-prominent max-w-xl text-slate-200">
					{player.description}
				</p>
			</div>

			<div class="mt-6 flex flex-wrap gap-3">
				<a
					href="#player-inventory"
					class="inline-flex rounded-md bg-gradient-to-b from-amber-300 to-amber-500 px-5 py-3 text-xs font-black uppercase text-black transition hover:brightness-110"
				>
					View Inventory
				</a>

				<a
					href="#player-overview"
					class="inline-flex rounded-md border border-sky-500 px-5 py-3 text-xs font-black uppercase text-white transition hover:bg-sky-500/10"
				>
					Player Overview
				</a>
			</div>
		</div>

		<div class="relative flex items-end justify-center">
			{playerImage && (
				<img
					src={playerImage}
					alt=""
					aria-hidden="true"
					class="max-h-[360px] w-full max-w-[460px] rounded-2xl object-cover object-top shadow-2xl ring-1 ring-amber-400/30"
				/>
			)}
		</div>
	</div>
</section>