---
import GridContainer from '../layout/GridContainer.astro';
import SportNavigationCarousel from '../navigation/SportNavigationCarousel.astro';
import PlayerNavigationTile from '../navigation/PlayerNavigationTile.astro';

const {
	players = [],
	debug = false,
} = Astro.props;
---

<section aria-label="Featured players">
	<div class="lg:hidden">
		<SportNavigationCarousel>
			{players.map((player) => (
				<PlayerNavigationTile
					name={player.name}
					href={player.href}
					image={player.image}
					meta={player.meta}
					eyebrow={player.eyebrow ?? 'Featured Player'}
					debug={debug}
					class="shrink-0 basis-[42%] snap-start sm:basis-[28%]"
				/>
			))}
		</SportNavigationCarousel>
	</div>

	<div class="hidden lg:block">
		<GridContainer columns="6" gap="default">
			{players.map((player) => (
				<PlayerNavigationTile
					name={player.name}
					href={player.href}
					image={player.image}
					meta={player.meta}
					eyebrow={player.eyebrow ?? 'Featured Player'}
					debug={debug}
				/>
			))}
		</GridContainer>
	</div>
</section>