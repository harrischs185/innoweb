---
import '../styles/global.css';
import UtilityHeaderStrip from '../components/header/UtilityHeaderStrip.astro';
import HeaderDivider from '../components/header/HeaderDivider.astro';
import SiteHeader from '../components/header/SiteHeader.astro';
import TrustAccessGrid from '../components/home/trust/TrustAccessGrid.astro';

const {
	title = 'InnoAV Sports Collectibles',
	description = 'Sports cards, collectibles, player pages, and hobby tools.',
	noindex = false,
    showFooterTrust = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

        <meta
            name="description"
            content={description}
        />

        {noindex && (
            <meta
                name="robots"
                content="noindex,nofollow"
            />
        )}
	</head>
	<body>
        <UtilityHeaderStrip />
        <HeaderDivider width="full" />
        <SiteHeader />
        <HeaderDivider />

        <main class="layout-page bg-black px-6 py-0 text-white md:px-12">
            <slot />

            {showFooterTrust && <TrustAccessGrid />}
        </main>
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
        background: black;
		color: white;
	}

    .layout-page {
        min-height: 100vh;
        overflow-x: clip;
        background: black;
    }

    .layout-section {
        padding-block: clamp(2rem, 5vw, 5rem);
    }

    .layout-section-tight {
        padding-block: clamp(1rem, 2.5vw, 2.5rem);
    }

    .layout-section-loose {
        padding-block: clamp(3rem, 7vw, 7rem);
    }

    .layout-section-hero {
        padding-block: clamp(3rem, 8vw, 9rem);
    }

    .layout-section-flush {
        padding-block: 0;
    }

    .layout-section-top-tight {
        padding-top: clamp(1rem, 2.5vw, 2.5rem);
    }

    .layout-section-bottom-tight {
        padding-bottom: clamp(1rem, 2.5vw, 2.5rem);
    }

    .layout-container {
        width: min(calc(100% - clamp(1rem, 4vw, 4rem)), 1280px);
        margin-inline: auto;
    }

    .layout-container-wide {
        width: min(calc(100% - clamp(1rem, 3vw, 3rem)), 1536px);
        margin-inline: auto;
    }

    .layout-container-narrow {
        width: min(calc(100% - clamp(1rem, 5vw, 5rem)), 860px);
        margin-inline: auto;
    }

    .layout-full-bleed {
        width: 100%;
    }

    .layout-debug {
        border: 2px solid red;
        background: rgba(255, 0, 0, 0.05);
    }

    .layout-debug-inner {
        border: 2px solid cyan;
        background: rgba(0, 255, 255, 0.05);
    }

    .layout-demo-block {
        min-height: 180px;
        padding: clamp(1rem, 3vw, 2.5rem);
    }

</style>
